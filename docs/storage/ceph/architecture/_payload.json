de",{"__ignoreMap":570},[575,576,579],"span",{"class":577,"line":578},"line",1,[575,580,582],{"class":581},"sTEyZ","graph LR\n",[575,584,586],{"class":577,"line":585},2,[575,587,588],{"class":581},"subgraph Pool\n",[575,590,592],{"class":577,"line":591},3,[575,593,594],{"class":581},"    subgraph PG-2[PG 2]\n",[575,596,598],{"class":577,"line":597},4,[575,599,600],{"class":581},"        Object-1[Object 1]\n",[575,602,604],{"class":577,"line":603},5,[575,605,606],{"class":581},"        Object-2[Object 2]\n",[575,608,610],{"class":577,"line":609},6,[575,611,612],{"class":581},"    end\n",[575,614,616],{"class":577,"line":615},7,[575,617,619],{"emptyLinePlaceholder":618},true,"\n",[575,621,623],{"class":577,"line":622},8,[575,624,625],{"class":581},"    subgraph PG-1[PG 1]\n",[575,627,629],{"class":577,"line":628},9,[575,630,631],{"class":581},"        Object-3[Object 3]\n",[575,633,635],{"class":577,"line":634},10,[575,636,637],{"class":581},"        Object-4[Object 4]\n",[575,639,641],{"class":577,"line":640},11,[575,642,612],{"class":581},[575,644,646],{"class":577,"line":645},12,[575,647,648],{"class":581},"end\n",[518,650,652],{"id":651},"ceph-cluster-components","Ceph Cluster Components",[558,654,656],{"id":655},"mon-monitor-daemon","MON - Monitor Daemon",[514,658,659,660,664],{},"The MONs are keeping a ",[661,662,663],"strong",{},"map"," of the current MONs, OSDs, PGs, Pools and so on.",[514,666,667],{},"MONs require a quorum to function, meaning that you should always run at least 3 mons for production 5 can be a good idea as well.",[563,669,670],{},[566,671,673],{"className":568,"code":672,"language":563,"meta":570,"style":570},"graph LR\n    MON-A[\"MON A\"]\n    MON-B[\"MON B\"]\n    MON-C[\"MON C\"]\n\n    MON-A -.- MON-B\n    MON-A -.- MON-C\n",[572,674,675,679,684,689,694,698,703],{"__ignoreMap":570},[575,676,677],{"class":577,"line":578},[575,678,582],{"class":581},[575,680,681],{"class":577,"line":585},[575,682,683],{"class":581},"    MON-A[\"MON A\"]\n",[575,685,686],{"class":577,"line":591},[575,687,688],{"class":581},"    MON-B[\"MON B\"]\n",[575,690,691],{"class":577,"line":597},[575,692,693],{"class":581},"    MON-C[\"MON C\"]\n",[575,695,696],{"class":577,"line":603},[575,697,619],{"emptyLinePlaceholder":618},[575,699,700],{"class":577,"line":609},[575,701,702],{"class":581},"    MON-A -.- MON-B\n",[575,704,705],{"class":577,"line":615},[575,706,707],{"class":581},"    MON-A -.- MON-C\n",[514,709,710,713,714],{},[661,711,712],{},"Man Page",": ",[715,716,717],"a",{"href":717,"rel":718},"https:\u002F\u002Fdocs.ceph.com\u002Fen\u002Flatest\u002Fman\u002F8\u002Fceph-mon\u002F",[719],"nofollow",[721,722,724],"h4",{"id":723},"quorum","Quorum",[514,726,727],{},"Simply put, if you run with 3 MONs you can lose 1 MON before the cluster will come to a halt as the quorum would be lost.",[729,730,731,744],"table",{},[732,733,734],"thead",{},[735,736,737,741],"tr",{},[738,739,740],"th",{},"MONs",[738,742,743],{},"How many can be lost?",[745,746,747,756,763,770,777,784,791],"tbody",{},[735,748,749,753],{},[750,751,752],"td",{},"1",[750,754,755],{},"0",[735,757,758,761],{},[750,759,760],{},"2",[750,762,755],{},[735,764,765,768],{},[750,766,767],{},"3",[750,769,752],{},[735,771,772,775],{},[750,773,774],{},"4",[750,776,752],{},[735,778,779,782],{},[750,780,781],{},"5",[750,783,760],{},[735,785,786,789],{},[750,787,788],{},"6",[750,790,760],{},[735,792,793,796],{},[750,794,795],{},"7",[750,797,767],{},[514,799,800,801,806],{},"For more information regarding quorum, checkout the following link from the ETCD documentation: ",[715,802,805],{"href":803,"rel":804},"https:\u002F\u002Fetcd.io\u002Fdocs\u002Fv3.3\u002Ffaq\u002F#why-an-odd-number-of-cluster-members",[719],"ETCD v3.3. - FAQ Why an odd number of cluster members?",".\nETCD is a good example of an infrastructure critical application (for Kubernetes) which requires a Quorum for (most; depending on your settings) operations.",[558,808,810],{"id":809},"mgr-manager-daemon","MGR - Manager Daemon",[514,812,813,814,817,818,821],{},"The MGR daemon(s) \"provide additional monitoring and interfaces to external monitoring and management systems\". You need to have at least one running as otherwise certain status information in, e.g., ",[572,815,816],{},"ceph status"," (",[572,819,820],{},"ceph -s","), will not be shown.\nIt is recommended to run at least 1.",[514,823,824],{},"The MGR daemon(s) talk with the MON, OSD MDS, and even RGW.",[563,826,827],{},[566,828,830],{"className":568,"code":829,"language":563,"meta":570,"style":570},"---\nconfig:\n  layout: elk\n---\ngraph LR\n    MGR --> MON\n    MGR --> OSD\n    MGR --> MDS\n    MGR --> RGW\n",[572,831,832,837,842,847,851,855,860,865,870],{"__ignoreMap":570},[575,833,834],{"class":577,"line":578},[575,835,836],{"class":581},"---\n",[575,838,839],{"class":577,"line":585},[575,840,841],{"class":581},"config:\n",[575,843,844],{"class":577,"line":591},[575,845,846],{"class":581},"  layout: elk\n",[575,848,849],{"class":577,"line":597},[575,850,836],{"class":581},[575,852,853],{"class":577,"line":603},[575,854,582],{"class":581},[575,856,857],{"class":577,"line":609},[575,858,859],{"class":581},"    MGR --> MON\n",[575,861,862],{"class":577,"line":615},[575,863,864],{"class":581},"    MGR --> OSD\n",[575,866,867],{"class":577,"line":622},[575,868,869],{"class":581},"    MGR --> MDS\n",[575,871,872],{"class":577,"line":628},[575,873,874],{"class":581},"    MGR --> RGW\n",[514,876,877],{},"The MGR daemon(s) have many modules to for example provide metrics for Prometheus, Zabbix and others. In addition to that a Ceph dashboard can be activated which contains some basic information and even an integration with Prometheus and Grafana.",[514,879,880,713,882],{},[661,881,712],{},[715,883,884],{"href":884,"rel":885},"https:\u002F\u002Fdocs.ceph.com\u002Fen\u002Flatest\u002Fmgr\u002Findex.html",[719],[558,887,889],{"id":888},"osd-object-storage-daemon","OSD - Object Storage Daemon",[514,891,892],{},"All OSDs normally talk with each other for hearbeat ❤️ checking and data replication (actual data and also for data \"scrubbing\" operations).",[563,894,895],{},[566,896,898],{"className":568,"code":897,"language":563,"meta":570,"style":570},"---\nconfig:\n  layout: elk\n---\ngraph LR\n    OSD-0\n    OSD-0 -.- OSD-1\n    OSD-0 -.- OSD-2\n    OSD-0 -.- OSD-n\n\n    OSD-1\n    OSD-1 -.- OSD-0\n    OSD-1 -.- OSD-2\n    OSD-1 -.- OSD-n\n\n    OSD-2\n    OSD-2 -.- OSD-0\n    OSD-2 -.- OSD-1\n    OSD-2 -.- OSD-n\n\n    OSD-n\n    OSD-n -.- OSD-0\n    OSD-n -.- OSD-1\n    OSD-n -.- OSD-2\n",[572,899,900,904,908,912,916,920,925,930,935,940,944,949,954,960,966,971,977,983,989,995,1000,1006,1012,1018],{"__ignoreMap":570},[575,901,902],{"class":577,"line":578},[575,903,836],{"class":581},[575,905,906],{"class":577,"line":585},[575,907,841],{"class":581},[575,909,910],{"class":577,"line":591},[575,911,846],{"class":581},[575,913,914],{"class":577,"line":597},[575,915,836],{"class":581},[575,917,918],{"class":577,"line":603},[575,919,582],{"class":581},[575,921,922],{"class":577,"line":609},[575,923,924],{"class":581},"    OSD-0\n",[575,926,927],{"class":577,"line":615},[575,928,929],{"class":581},"    OSD-0 -.- OSD-1\n",[575,931,932],{"class":577,"line":622},[575,933,934],{"class":581},"    OSD-0 -.- OSD-2\n",[575,936,937],{"class":577,"line":628},[575,938,939],{"class":581},"    OSD-0 -.- OSD-n\n",[575,941,942],{"class":577,"line":634},[575,943,619],{"emptyLinePlaceholder":618},[575,945,946],{"class":577,"line":640},[575,947,948],{"class":581},"    OSD-1\n",[575,950,951],{"class":577,"line":645},[575,952,953],{"class":581},"    OSD-1 -.- OSD-0\n",[575,955,957],{"class":577,"line":956},13,[575,958,959],{"class":581},"    OSD-1 -.- OSD-2\n",[575,961,963],{"class":577,"line":962},14,[575,964,965],{"class":581},"    OSD-1 -.- OSD-n\n",[575,967,969],{"class":577,"line":968},15,[575,970,619],{"emptyLinePlaceholder":618},[575,972,974],{"class":577,"line":973},16,[575,975,976],{"class":581},"    OSD-2\n",[575,978,980],{"class":577,"line":979},17,[575,981,982],{"class":581},"    OSD-2 -.- OSD-0\n",[575,984,986],{"class":577,"line":985},18,[575,987,988],{"class":581},"    OSD-2 -.- OSD-1\n",[575,990,992],{"class":577,"line":991},19,[575,993,994],{"class":581},"    OSD-2 -.- OSD-n\n",[575,996,998],{"class":577,"line":997},20,[575,999,619],{"emptyLinePlaceholder":618},[575,1001,1003],{"class":577,"line":1002},21,[575,1004,1005],{"class":581},"    OSD-n\n",[575,1007,1009],{"class":577,"line":1008},22,[575,1010,1011],{"class":581},"    OSD-n -.- OSD-0\n",[575,1013,1015],{"class":577,"line":1014},23,[575,1016,1017],{"class":581},"    OSD-n -.- OSD-1\n",[575,1019,1021],{"class":577,"line":1020},24,[575,1022,1023],{"class":581},"    OSD-n -.- OSD-2\n",[523,1025,1026,1029,1032],{},[526,1027,1028],{},"If a client writes data, the data is replicated by the OSD and not the client.",[526,1030,1031],{},"If a client reads data, the data can be read from multiple OSDs at the same time (as long as they have a replica of the data).",[526,1033,1034,713,1037],{},[661,1035,1036],{},"Side note",[1038,1039,1040],"em",{},"That is the reason why read speeds are so fast and writes can be so slow. One slow OSD can \"ruin your day\" because of that.",[514,1042,1043,713,1045],{},[661,1044,712],{},[715,1046,1047],{"href":1047,"rel":1048},"https:\u002F\u002Fdocs.ceph.com\u002Fen\u002Flatest\u002Fman\u002F8\u002Fceph-osd\u002F",[719],[558,1050,1052],{"id":1051},"mds-metadata-server-daemon","MDS - Metadata Server Daemon",[514,1054,1055],{},"The MDS is the metadata server for the CephFilesystem (CephFS).",[514,1057,1058],{},"It talks with the OSDs and coordinates the filesystem access. Clients still need to access the OSDs, but the MDS is the \"gateway\" to know where to go so to say.",[563,1060,1061],{},[566,1062,1064],{"className":568,"code":1063,"language":563,"meta":570,"style":570},"---\nconfig:\n  layout: elk\n---\ngraph LR\n    Client-A --> MDS-1\n    Client-B --> MDS-1\n    Client-C ---> MDS-2\n\n    MDS-1 -.- MDS-2\n    MDS-1 --> OSDs\n    MDS-2 --> OSDs\n\n    Client-A ---> OSDs\n    Client-B ---> OSDs\n    Client-C ---> OSDs\n",[572,1065,1066,1070,1074,1078,1082,1086,1091,1096,1101,1105,1110,1115,1120,1124,1129,1134],{"__ignoreMap":570},[575,1067,1068],{"class":577,"line":578},[575,1069,836],{"class":581},[575,1071,1072],{"class":577,"line":585},[575,1073,841],{"class":581},[575,1075,1076],{"class":577,"line":591},[575,1077,846],{"class":581},[575,1079,1080],{"class":577,"line":597},[575,1081,836],{"class":581},[575,1083,1084],{"class":577,"line":603},[575,1085,582],{"class":581},[575,1087,1088],{"class":577,"line":609},[575,1089,1090],{"class":581},"    Client-A --> MDS-1\n",[575,1092,1093],{"class":577,"line":615},[575,1094,1095],{"class":581},"    Client-B --> MDS-1\n",[575,1097,1098],{"class":577,"line":622},[575,1099,1100],{"class":581},"    Client-C ---> MDS-2\n",[575,1102,1103],{"class":577,"line":628},[575,1104,619],{"emptyLinePlaceholder":618},[575,1106,1107],{"class":577,"line":634},[575,1108,1109],{"class":581},"    MDS-1 -.- MDS-2\n",[575,1111,1112],{"class":577,"line":640},[575,1113,1114],{"class":581},"    MDS-1 --> OSDs\n",[575,1116,1117],{"class":577,"line":645},[575,1118,1119],{"class":581},"    MDS-2 --> OSDs\n",[575,1121,1122],{"class":577,"line":956},[575,1123,619],{"emptyLinePlaceholder":618},[575,1125,1126],{"class":577,"line":962},[575,1127,1128],{"class":581},"    Client-A ---> OSDs\n",[575,1130,1131],{"class":577,"line":968},[575,1132,1133],{"class":581},"    Client-B ---> OSDs\n",[575,1135,1136],{"class":577,"line":973},[575,1137,1138],{"class":581},"    Client-C ---> OSDs\n",[514,1140,1141,713,1143],{},[661,1142,712],{},[715,1144,1145],{"href":1145,"rel":1146},"https:\u002F\u002Fdocs.ceph.com\u002Fen\u002Flatest\u002Fman\u002F8\u002Fceph-mds\u002F",[719],[558,1148,1150],{"id":1149},"rgw-rados-rest-gateway","RGW - RADOS REST Gateway",[514,1152,1153],{},"RGW can offer S3 and\u002F or SWIFT compatible storage, allowing to use it as a \"replacement\" for AWS S3 object storage in some cases.\nAn advantage to, e.g., the block storage (RBD) and CephFS is that the client itself does not need direct access to the MONs, OSDs, etc., though it depends on the use case and the performance required per client\u002F application.",[563,1155,1156],{},[566,1157,1159],{"className":568,"code":1158,"language":563,"meta":570,"style":570},"---\nconfig:\n  layout: elk\n---\ngraph LR\n    Client-A --> RGW-1\n    Client-B --> RGW-1\n    Client-C --> RGW-2\n    RGW-1 --> OSDs\n    RGW-2 --> OSDs\n",[572,1160,1161,1165,1169,1173,1177,1181,1186,1191,1196,1201],{"__ignoreMap":570},[575,1162,1163],{"class":577,"line":578},[575,1164,836],{"class":581},[575,1166,1167],{"class":577,"line":585},[575,1168,841],{"class":581},[575,1170,1171],{"class":577,"line":591},[575,1172,846],{"class":581},[575,1174,1175],{"class":577,"line":597},[575,1176,836],{"class":581},[575,1178,1179],{"class":577,"line":603},[575,1180,582],{"class":581},[575,1182,1183],{"class":577,"line":609},[575,1184,1185],{"class":581},"    Client-A --> RGW-1\n",[575,1187,1188],{"class":577,"line":615},[575,1189,1190],{"class":581},"    Client-B --> RGW-1\n",[575,1192,1193],{"class":577,"line":622},[575,1194,1195],{"class":581},"    Client-C --> RGW-2\n",[575,1197,1198],{"class":577,"line":628},[575,1199,1200],{"class":581},"    RGW-1 --> OSDs\n",[575,1202,1203],{"class":577,"line":634},[575,1204,1205],{"class":581},"    RGW-2 --> OSDs\n",[514,1207,1208],{},"Common scenario is that you have a load balancer in front of your RGWs, in itself the structure stays the same:",[563,1210,1211],{},[566,1212,1214],{"className":568,"code":1213,"language":563,"meta":570,"style":570},"---\nconfig:\n  layout: elk\n---\ngraph LR\n    Client-A --> Loadbalancer\n    Client-B --> Loadbalancer\n    Client-C --> Loadbalancer\n    Loadbalancer --> RGW-1\n    Loadbalancer --> RGW-2\n    RGW-1 --> OSDs\n    RGW-2 --> OSDs\n",[572,1215,1216,1220,1224,1228,1232,1236,1241,1246,1251,1256,1261,1265],{"__ignoreMap":570},[575,1217,1218],{"class":577,"line":578},[575,1219,836],{"class":581},[575,1221,1222],{"class":577,"line":585},[575,1223,841],{"class":581},[575,1225,1226],{"class":577,"line":591},[575,1227,846],{"class":581},[575,1229,1230],{"class":577,"line":597},[575,1231,836],{"class":581},[575,1233,1234],{"class":577,"line":603},[575,1235,582],{"class":581},[575,1237,1238],{"class":577,"line":609},[575,1239,1240],{"class":581},"    Client-A --> Loadbalancer\n",[575,1242,1243],{"class":577,"line":615},[575,1244,1245],{"class":581},"    Client-B --> Loadbalancer\n",[575,1247,1248],{"class":577,"line":622},[575,1249,1250],{"class":581},"    Client-C --> Loadbalancer\n",[575,1252,1253],{"class":577,"line":628},[575,1254,1255],{"class":581},"    Loadbalancer --> RGW-1\n",[575,1257,1258],{"class":577,"line":634},[575,1259,1260],{"class":581},"    Loadbalancer --> RGW-2\n",[575,1262,1263],{"class":577,"line":640},[575,1264,1200],{"class":581},[575,1266,1267],{"class":577,"line":645},[575,1268,1205],{"class":581},[514,1270,1271,713,1273],{},[661,1272,712],{},[715,1274,1275],{"href":1275,"rel":1276},"https:\u002F\u002Fdocs.ceph.com\u002Fen\u002Flatest\u002Fman\u002F8\u002Fradosgw\u002F",[719],[1278,1279],"hr",{},[514,1281,1282,1287,1288,1293],{},[715,1283,1286],{"href":1284,"rel":1285},"https:\u002F\u002Fgithub.com\u002FTheJJ\u002Fceph-cheatsheet",[719],"This wonderful Ceph cheat sheet"," from ",[715,1289,1292],{"href":1290,"rel":1291},"https:\u002F\u002Fgithub.com\u002FTheJJ",[719],"@TheJJ on GitHub"," has much more insight into the processes, tricks and setup of a Ceph cluster and the moving parts.",[1278,1295],{},[518,1297,1299],{"id":1298},"old-diagrams","Old Diagrams",[514,1301,1302],{},[1038,1303,1304,1305,1308],{},"The source for the diagrams, can be found as ",[572,1306,1307],{},".graphml"," at the same path as the images.",[558,1310,1312],{"id":1311},"basic-cluster-with-hdds-and-ssds","Basic Cluster with HDDs and SSDs",[514,13