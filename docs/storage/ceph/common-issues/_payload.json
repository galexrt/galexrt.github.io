87,588,589],{},"References:\n",[530,590,591,597],{},[533,592,593],{},[541,594,595],{"href":595,"rel":596},"https:\u002F\u002Ftracker.ceph.com\u002Fprojects\u002Fceph\u002Fwiki\u002FBenchmark_Ceph_Cluster_Performance",[545],[533,598,599],{},[541,600,601],{"href":601,"rel":602},"https:\u002F\u002Fedenmal.moe\u002Fpost\u002F2017\u002FCeph-rbd-bench-Commands\u002F",[545],[514,604,606],{"id":605},"cephfs-mount-issues-on-hosts","CephFS mount issues on Hosts",[519,608,609,610,613],{},"Make sure you have a (active) Linux kernel of version ",[547,611,612],{},"4.17"," or higher.",[615,616,618],"callout",{"icon":617},"i-ph-lightbulb-filament",[519,619,620,623,624,627],{},[525,621,622],{},"Tip",":\nIn general it is recommended to have a very up-to-date version of the Linux kernel, as many improvements have been made to the Ceph kernel drivers in newer kernel versions (",[547,625,626],{},"5.x"," or higher).",[514,629,631],{"id":630},"health_warn-1-large-omap-objects",[547,632,633],{},"HEALTH_WARN 1 large omap objects",[635,636,638],"h3",{"id":637},"issue","Issue",[640,641,646],"pre",{"className":642,"code":644,"language":645},[643],"language-text","HEALTH_WARN 1 large omap objects\n# and\u002For\nLARGE_OMAP_OBJECTS 1 large omap objects\n","text",[547,647,644],{"__ignoreMap":648},"",[635,650,652],{"id":651},"solution","Solution",[519,654,655],{},"The following command should fix the issue:",[640,657,661],{"className":658,"code":659,"language":660,"meta":648,"style":648},"language-bash shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","radosgw-admin reshard stale-instances rm\n","bash",[547,662,663],{"__ignoreMap":648},[664,665,668,672,676,679],"span",{"class":666,"line":667},"line",1,[664,669,671],{"class":670},"sBMFI","radosgw-admin",[664,673,675],{"class":674},"sfazB"," reshard",[664,677,678],{"class":674}," stale-instances",[664,680,681],{"class":674}," rm\n",[514,683,685],{"id":684},"mdss-report-oversized-cache",[547,686,687],{},"MDSs report oversized cache",[635,689,638],{"id":690},"issue-1",[519,692,693,694,697],{},"Ceph health status reports, e.g., ",[547,695,696],{},"1 MDSs report oversized cache",".",[640,699,702],{"className":700,"code":701,"language":645},[643],"[root@rook-ceph-tools-86d54cbd8d-6ktjh \u002F]# ceph -s\n  cluster:\n    id:     67e1ce27-0405-441e-ad73-724c93b7aac4\n    health: HEALTH_WARN\n            1 MDSs report oversized cache\n[...]\n",[547,703,701],{"__ignoreMap":648},[635,705,652],{"id":706},"solution-1",[519,708,709,710,713,714,697],{},"You can try to increase the ",[547,711,712],{},"mds cache memory limit"," setting",[715,716,717],"sup",{},[541,718,723],{"href":719,"ariaDescribedBy":720,"dataFootnoteRef":648,"id":722},"#user-content-fn-1",[721],"footnote-label","user-content-fnref-1","1",[615,725,726],{"icon":617},[519,727,728,730,731,697],{},[525,729,622],{},":\nFor Rook Ceph users, you set\u002Fincrease the memory requests on the CephFilesystem object for the MDS daemons",[715,732,733],{},[541,734,738],{"href":735,"ariaDescribedBy":736,"dataFootnoteRef":648,"id":737},"#user-content-fn-2",[721],"user-content-fnref-2","2",[514,740,742],{"id":741},"find-device-osd-is-using","Find Device OSD is using",[635,744,638],{"id":745},"issue-2",[519,747,748],{},"You need to find out which disk\u002Fdevice is used by an OSD daemon.",[519,750,751,754,755,758],{},[525,752,753],{},"Scenarios",": ",[547,756,757],{},"smartctl"," is showing that the disk should be replaced, disk has already failed, etc.",[635,760,652],{"id":761},"solution-2",[519,763,764,765,768,769,697],{},"Use the various ",[547,766,767],{},"ls*"," subcommands of ",[547,770,771],{},"ceph device",[640,773,775],{"className":658,"code":774,"language":660,"meta":648,"style":648},"$ ceph device --help\ndevice check-health                                                         Check life expectancy of devices\ndevice get-health-metrics \u003Cdevid> [\u003Csample>]                                Show stored device metrics for the device\ndevice info \u003Cdevid>                                                         Show information about a device\ndevice light on|off \u003Cdevid> [ident|fault] [--force]                         Enable or disable the device light. Default type is `ident`\n'Usage: device\n                                                                             light (on|off) \u003Cdevid> [ident|fault] [--force]'\ndevice ls                                                                   Show devices\ndevice ls-by-daemon \u003Cwho>                                                   Show devices associated with a daemon\ndevice ls-by-host \u003Chost>                                                    Show devices on a host\ndevice ls-lights                                                            List currently active device indicator lights\ndevice monitoring off                                                       Disable device health monitoring\ndevice monitoring on                                                        Enable device health monitoring\ndevice predict-life-expectancy \u003Cdevid>                                      Predict life expectancy with local predictor\ndevice query-daemon-health-metrics \u003Cwho>                                    Get device health metrics for a given daemon\ndevice rm-life-expectancy \u003Cdevid>                                           Clear predicted device life expectancy\ndevice scrape-daemon-health-metrics \u003Cwho>                                   Scrape and store device health metrics for a given daemon\ndevice scrape-health-metrics [\u003Cdevid>]                                      Scrape and store device health metrics\ndevice set-life-expectancy \u003Cdevid> \u003Cfrom> [\u003Cto>]                            Set predicted device life expectancy\n",[547,776,777,791,815,847,878,923,929,935,948,983,1013,1038,1060,1078,1109,1145,1174,1213,1224],{"__ignoreMap":648},[664,778,779,782,785,788],{"class":666,"line":667