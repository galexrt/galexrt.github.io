:22},"Tiptap","i-mdi-file-edit-outline","\u002Fdocs\u002Fweb\u002Ftiptap","1.docs\u002Fweb\u002Ftiptap",[504],{"title":505,"path":506,"stem":507},"Snippets","\u002Fdocs\u002Fweb\u002Ftiptap\u002Fsnippets","1.docs\u002Fweb\u002Ftiptap\u002Fsnippets",{"id":509,"title":154,"body":510,"description":554,"extension":749,"meta":750,"navigation":730,"path":155,"seo":752,"stem":156,"__hash__":753},"docs\u002F1.docs\u002Fkubernetes\u002Fetcd\u002Fsnapshots-save-restore.md",{"type":511,"value":512,"toc":745},"minimark",[513,530,543,548,602,609,613,620,627,634,637,738,741],[514,515,517],"callout",{"icon":516},"i-ph-lightbulb-filament",[518,519,520,524,525,529],"p",{},[521,522,523],"strong",{},"Warning",":\nThis page is only for ETCD version ",[526,527,528],"code",{},"3.x"," and higher!",[531,532,533],"blockquote",{},[518,534,535,536,542],{},"For the original commands and more information on ETCD, see ",[537,538,539],"a",{"href":539,"rel":540},"https:\u002F\u002Fcoreos.com\u002Fetcd\u002Fdocs\u002Flatest\u002Fop-guide\u002Frecovery.html",[541],"nofollow",".",[544,545,547],"h2",{"id":546},"take-a-snapshot","Take a snapshot",[549,550,555],"pre",{"className":551,"code":552,"language":553,"meta":554,"style":554},"language-bash shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","ETCDCTL_API=3 etcdctl \\\n    --endpoints $ETCD_ENDPOINT \\\n    snapshot save snapshot.db\n","bash","",[526,556,557,581,590],{"__ignoreMap":554},[558,559,562,566,570,574,578],"span",{"class":560,"line":561},"line",1,[558,563,565],{"class":564},"sTEyZ","ETCDCTL_API",[558,567,569],{"class":568},"sMK4o","=",[558,571,573],{"class":572},"sfazB","3",[558,575,577],{"class":576},"sBMFI"," etcdctl",[558,579,580],{"class":564}," \\\n",[558,582,584,587],{"class":560,"line":583},2,[558,585,586],{"class":572},"    --endpoints",[558,588,589],{"class":564}," $ETCD_ENDPOINT \\\n",[558,591,593,596,599],{"class":560,"line":592},3,[558,594,595],{"class":572},"    snapshot",[558,597,598],{"class":572}," save",[558,600,601],{"class":572}," snapshot.db\n",[518,603,604,605,608],{},"(where ",[526,606,607],{},"snapshot.db"," is the name of the snapshot file to be created)",[544,610,612],{"id":611},"restore-a-snapshot","Restore a snapshot",[514,614,615],{"icon":516},[518,616,617,619],{},[521,618,523],{},":\nBefore restoring a snapshot, all ETCDs in the cluster must be stopped!",[518,621,622,623,626],{},"You must rename\u002Fremove the current data dir (probably ",[526,624,625],{},"\u002Fvar\u002Flib\u002Fetcd",").",[518,628,629,630,633],{},"Be sure to provide all flags that are specified in, e.g., systemd unit file, Kubespray: ",[526,631,632],{},"\u002Fetc\u002Fetcd.env"," and others otherwise you may create issues for the ETCD cluster!",[518,635,636],{},"The command is looking about like that depending on what flags are used for your ETCD node:",[549,638,640],{"className":551,"code":639,"language":553,"meta":554,"style":554},"# Run the command as `root` user after that use `chown` to correct ownership of files\nETCDCTL_API=3 etcdctl \\\n    snapshot restore snapshot.db \\\n    --name m1 \\\n    --initial-cluster m1=http:\u002F\u002Fhost1:2380,m2=http:\u002F\u002Fhost2:2380,m3=http:\u002F\u002Fhost3:2380 \\\n    --initial-cluster-token etcd-cluster-1 \\\n    --initial-advertise-peer-urls http:\u002F\u002Fhost1:2380\n    --data-dir=\u002Fvar\u002Flib\u002Fetcd\n\n# chown etcd:etcd -R \u002Fvar\u002Flib\u002Fetcd\n",[526,641,642,648,660,672,683,694,705,714,725,732],{"__ignoreMap":554},[558,643,644],{"class":560,"line":561},[558,645,647],{"class":646},"sHwdD","# Run the command as `root` user after that use `chown` to correct ownership of files\n",[558,649,650,652,654,656,658],{"class":560,"line":583},[558,651,565],{"class":564},[558,653,569],{"class":568},[558,655,573],{"class":572},[558,657,577],{"class":576},[558,659,580],{"class":564},[558,661,662,664,667,670],{"class":560,"line":592},[558,663,595],{"class":572},[558,665,666],{"class":572}," restore",[558,668,669],{"class":572}," snapshot.db",[558,671,580],{"class":564},[558,673,675,678,681],{"class":560,"line":674},4,[558,676,677],{"class":572},"    --name",[558,679,680],{"class":572}," m1",[558,682,580],{"class":564},[558,684,686,689,692],{"class":560,"line":685},5,[558,687,688],{"class":572},"    --initial-cluster",[558,690,691],{"class":572}," m1=http:\u002F\u002Fhost1:2380,m2=http:\u002F\u002Fhost2:2380,m3=http:\u002F\u002Fhost3:2380",[558,693,580],{"class":564},[558,695,697,700,703],{"class":560,"line":696},6,[558,698,699],{"class":572},"    --initial-cluster-token",[558,701,702],{"class":572}," etcd-cluster-1",[558,704,580],{"class":564},[558,706,708,711],{"class":560,"line":707},7,[558,709,710],{"class":572},"    --initial-advertise-peer-urls",[558,712,713],{"class":572}," http:\u002F\u002Fhost1:2380\n",[558,715,717,720,722],{"class":560,"line":716},8,[558,718,719],{"class":564},"    --data-dir",[558,721,569],{"class":568},[558,723,724],{"class":572},"\u002Fvar\u002Flib\u002Fetcd\n",[558,726,728],{"class":560,"line":727},9,[558,729,731],{"emptyLinePlaceholder":730},true,"\n",[558,733,735],{"class":560,"line":734},10,[558,736,737],{"class":646},"# chown etcd:etcd -R \u002Fvar\u002Flib\u002Fetcd\n",[518,739,740],{},"This has to be done on all ETCD servers one by one with each having their own name given by flag as they were when the snapshot was taken.",[742,743,744],"style",{},"html pre.shiki code .sTEyZ, html code.shiki .sTEyZ{--shiki-light:#90A4AE;--shiki-default:#EEFFFF;--shiki-dark:#BABED8}html pre.shiki code .sMK4o, html code.shiki .sMK4o{--shiki-light:#39ADB5;--shiki-default:#89DDFF;--shiki-dark:#89DDFF}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859;--shiki-default:#C3E88D;--shiki-dark:#C3E88D}html pre.shiki code .sBMFI, html code.shiki .sBMFI{--shiki-light:#E2931D;--shiki-default:#FFCB6B;--shiki-dark:#FFCB6B}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);