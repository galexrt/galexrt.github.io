oor_bell\n          then:\n            - binary_sensor.template.publish:\n                id: my_door_bell\n                state: on\n            - delay: 6s\n            - binary_sensor.template.publish:\n                id: my_door_bell\n                state: off\n","yaml",[572,721,722,732,744,760,764,771,781,788,798,802,808,815,825,829,834,841,848,862,866,873,886,900,904,911,926,939,945,953,965,979,990,1005,1011,1022,1034,1039,1047,1059,1070,1083,1097,1108,1119,1130,1138,1153,1161,1172,1180,1188,1196,1206,1214,1225,1235,1246,1259,1268,1277],{"__ignoreMap":570},[575,723,724,728],{"class":577,"line":578},[575,725,727],{"class":726},"swJcz","esphome",[575,729,731],{"class":730},"sMK4o",":\n",[575,733,734,737,740],{"class":577,"line":585},[575,735,736],{"class":726},"  name",[575,738,739],{"class":730},":",[575,741,743],{"class":742},"sfazB"," my-door-bell\n",[575,745,746,749,751,754,757],{"class":577,"line":591},[575,747,748],{"class":726},"  friendly_name",[575,750,739],{"class":730},[575,752,753],{"class":730}," \"",[575,755,756],{"class":742},"My Door Bell",[575,758,759],{"class":730},"\"\n",[575,761,762],{"class":577,"line":597},[575,763,636],{"emptyLinePlaceholder":635},[575,765,766,769],{"class":577,"line":602},[575,767,768],{"class":726},"esp32",[575,770,731],{"class":730},[575,772,773,776,778],{"class":577,"line":608},[575,774,775],{"class":726},"  board",[575,777,739],{"class":730},[575,779,780],{"class":742}," esp32dev\n",[575,782,783,786],{"class":577,"line":614},[575,784,785],{"class":726},"  framework",[575,787,731],{"class":730},[575,789,790,793,795],{"class":577,"line":620},[575,791,792],{"class":726},"    type",[575,794,739],{"class":730},[575,796,797],{"class":742}," arduino\n",[575,799,800],{"class":577,"line":626},[575,801,636],{"emptyLinePlaceholder":635},[575,803,804],{"class":577,"line":632},[575,805,807],{"class":806},"sHwdD","# Enable logging\n",[575,809,810,813],{"class":577,"line":639},[575,811,812],{"class":726},"logger",[575,814,731],{"