it-outline","\u002Fdocs\u002Fweb\u002Ftiptap","1.docs\u002Fweb\u002Ftiptap",[504],{"title":505,"path":506,"stem":507},"Snippets","\u002Fdocs\u002Fweb\u002Ftiptap\u002Fsnippets","1.docs\u002Fweb\u002Ftiptap\u002Fsnippets",{"id":509,"title":56,"body":510,"description":608,"extension":720,"meta":721,"navigation":722,"path":57,"seo":723,"stem":58,"__hash__":724},"docs\u002F1.docs\u002Fdatabases\u002Fmysql\u002Fpitfalls.md",{"type":511,"value":512,"toc":709},"minimark",[513,522,532,543,549,556,581,585,592,596,602,631,637,645,653,672,686,691,694,697,705],[514,515,517,521],"h2",{"id":516},"mysql-cli-console-password-character-limit",[518,519,520],"code",{},"mysql"," CLI Console Password Character \"Limit\"",[523,524,525,527,528,531],"p",{},[518,526,520],{}," command only reads in 79 characters of \"password\" from TTY\u002F \"console\". In my case I was copy'n'pasting\u002F the password store autotyping database passwords which doesn't work then (leads to ",[518,529,530],{},"Access denied for user"," errors because the password is wrong).\nThis \"limit\" doesn't seem to be documented anywhere I looked, so here we go. If you want to login to your users only use passwords 79 characters long when \"typing\" them on the console.",[523,533,534,535,542],{},"Thanks to this ",[536,537,541],"a",{"href":538,"rel":539},"https:\u002F\u002Fjira.mariadb.org\u002Fbrowse\u002FMXS-1766",[540],"nofollow","Jira ticket (MXS-1766)"," to pointing to the code behind the \"limitation\"!",[523,544,545,546,548],{},"I also need to give a shoutout to the people with which I reflected the issue and then stumbled upon the ",[518,547,520],{}," CLI limitation.",[523,550,551,555],{},[552,553,554],"strong",{},"Code references",":",[557,558,559,571],"ul",{},[560,561,562],"li",{},[536,563,566,567,570],{"href":564,"rel":565},"https:\u002F\u002Fgithub.com\u002FMariaDB\u002Fserver\u002Fblob\u002F10.3\u002Fclient\u002Fmysql.cc#L1959",[540],"GitHub MariaDB\u002Fserver - ",[518,568,569],{},"10.3\u002Fclient\u002Fmysql.cc"," Line 1959",[560,572,573],{},[536,574,566,577,580],{"href":575,"rel":576},"https:\u002F\u002Fgithub.com\u002FMariaDB\u002Fserver\u002Fblob\u002F10.3\u002Fmysys\u002Fget_password.c#L63",[540],[518,578,579],{},"10.3\u002Fmysys\u002Fget_password.c"," Line 63",[514,582,584],{"id":583},"replication-user-password-character-limit","Replication User Password Character Limit",[523,586,587,588,591],{},"The password for a replication user must be a maximum of ",[518,589,590],{},"32"," characters long.",[514,593,595],{"id":594},"mysql-memory-storage-size-suffixes","MySQL Memory\u002F Storage Size Suffixes",[523,597,598,601],{},[552,599,600],{},"TL;DR"," The suffixes are in \"Bytes\". E.g., 16M = 16777216 Bytes.",[603,604,609],"pre",{"className":605,"code":606,"language":607,"meta":608,"style":608},"language-bash shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","mysql --max_allowed_packet=16777216\nmysql --max_allowed_packet=16M\n","bash","",[518,610,611,623],{"__ignoreMap":608},[612,613,616,619],"span",{"class":614,"line":615},"line",1,[612,617,520],{"class":618},"sBMFI",[612,620,622],{"class":621},"sfazB"," --max_allowed_packet=16777216\n",[612,624,626,628],{"class":614,"line":625},2,[612,627,520],{"class":618},[612,629,630],{"class":621}," --max_allowed_packet=16M\n",[632,633,634],"blockquote",{},[523,635,636],{},"The first command specifies the value in bytes. The second specifies the value in megabytes. For variables that take a numeric value, the value can be given with a suffix of K, M, or G to indicate a multiplier of 1024, 10242 or 10243. (For example, when used to set max_allowed_packet, the suffixes indicate units of kilobytes, megabytes, or gigabytes.) As of MySQL 8.0.14, a suffix can also be T, P, and E to indicate a multiplier of 10244, 10245 or 10246. Suffix letters can be uppercase or lowercase.",[523,638,639,640],{},"Quoted from: ",[536,641,644],{"href":642,"rel":643},"https:\u002F\u002Fdev.mysql.com\u002Fdoc\u002Frefman\u002F8.0\u002Fen\u002Fprogram-variables.html",[540],"MySQL 8.0 Reference Manual - 4.2.2.5 Using Options to Set Program Variables",[514,646,648,649,652],{"id":647},"mariadb-json-data-type-limitations","MariaDB ",[518,650,651],{},"JSON"," Data Type \"Limitations\"",[632,654,655,658,661],{},[523,656,657],{},"The JSON alias was added to make it possible to use JSON columns in statement based replication from MySQL to MariaDB and to make it possible for MariaDB to read mysqldumps from MySQL.",[523,659,660],{},"JSON is an alias for LONGTEXT COLLATE utf8mb4_bin introduced for compatibility reasons with MySQL's JSON data type. MariaDB implements this as a LONGTEXT rather, as the JSON data type contradicts the SQL:2016 standard, and MariaDB's benchmarks indicate that performance is at least equivalent.",[523,662,663],{},[664,665,666,667],"em",{},"Source: ",[536,668,671],{"href":669,"rel":670},"https:\u002F\u002Fmariadb.com\u002Fdocs\u002Fserver\u002Freference\u002Fdata-types\u002Fstring-data-types\u002Fjson",[540],"JSON Data Type | Server | MariaDB Documentation",[523,673,674,675,677,678,681,682,685],{},"So don't wonder if you create a table with a ",[518,676,651],{}," column and then see it as ",[518,679,680],{},"LONGTEXT"," when you do a ",[518,683,684],{},"SHOW CREATE TABLE ..."," later on..",[687,688,690],"h3",{"id":689},"mariadb-vs-mysql-functionality-differences","MariaDB vs MySQL Functionality Differences",[523,692,693],{},"It feels that the \"drift\" of functionality between MariaDB and MySQL is more and more increasing over time.\nFor example, MariaDB doesn't support JSON multi-valued indexes, but MySQL 8.x does.",[523,695,696],{},"I wouldn't be too worried yet, but as someone who is developing an application that should run on \"any MySQL database\" it is something to keep in mind.",[523,698,699,700,704],{},"Be sure to checkout the pitfalls documented on this page and ",[536,701,703],{"href":702},"mariadb#mariadb-vs-mysql","the MariaDB vs. MySQL section here",".",[706,707,708],"style",{},"html pre.shiki code .sBMFI, html code.shiki .sBMFI{--shiki-light:#E2931D;--shiki-default:#FFCB6B;--shiki-dark:#FFCB6B}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859;--shiki-default:#C3E88D;--shiki-dark:#C3E88D}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}",{"title":608,"searchDepth":625,"depth":625,"links":710},[711,713,714,715],{"id":516,"depth":625,"text":712},"mysql CLI Console Password Character \"Limit\"",{"id":583,"depth":625,"text":584},{"id":594,"depth":625,"text":595},{"id":647,"depth":625,"text":716,"children":717},"MariaDB JSON Data Type \"Limitations\"",[718],{"id":689,"depth":719,"text":690},3,"md",{},true,{"title":56,"description":608},"oetfxCD37xCSyOKfJnr_5mQjSJBSmQQ8gGAx0MmYJkM",[726,727],{"title":52,"path":53,"stem":54,"description":608,"children":-1},{"title":60,"path":61,"stem":62,"description":608,"children":-1},1776725961535]