size=10G $RBD_IMAGE_NAME\n","bash","",[565,566,567,590],"code",{"__ignoreMap":563},[568,569,572,576,580,584,587],"span",{"class":570,"line":571},"line",1,[568,573,575],{"class":574},"sBMFI","$",[568,577,579],{"class":578},"sfazB"," RBD_IMAGE_NAME=",[568,581,583],{"class":582},"sMK4o","\"",[568,585,586],{"class":578},"bench1",[568,588,589],{"class":582},"\"\n",[568,591,593,595,598,601,604],{"class":570,"line":592},2,[568,594,575],{"class":574},[568,596,597],{"class":578}," rbd",[568,599,600],{"class":578}," create",[568,602,603],{"class":578}," --size=10G",[568,605,607],{"class":606},"sTEyZ"," $RBD_IMAGE_NAME\n",[522,609,611],{"id":610},"rbd-bench","rbd bench",[613,614,616],"h3",{"id":615},"flags","Flags",[527,618,619,620,623],{},"Takes normal ",[565,621,622],{},"rbd"," command flags like:",[625,626,627],"ul",{},[628,629,630,633,634,637],"li",{},[565,631,632],{},"-p"," or ",[565,635,636],{},"--pool"," for the rbd pool to use.",[527,639,640],{},"The following flags are for the benchmark configuration:",[625,642,643,649,655,661,667],{},[628,644,645,648],{},[565,646,647],{},"--io-type"," if read or write IO should be run.",[628,650,651,654],{},[565,652,653],{},"--io-size"," how big every IO should be (in B\u002FK\u002FM\u002FG\u002FT).",[628,656,657,660],{},[565,658,659],{},"--io-threads"," how many IOs are done in parallel.",[628,662,663,666],{},[565,664,665],{},"--io-total"," how much total IO should be done.",[628,668,669,672],{},[565,670,671],{},"--io-pattern"," sequential or random IO pattern.",[613,674,676],{"id":675},"benchmarks","Benchmarks",[678,679,681],"h4",{"id":680},"write-benchmark","Write Benchmark",[527,683,684],{},"For sequential write benchmark:",[558,686,688],{"className":560,"code":687,"language":562,"meta":563,"style":563},"$ rbd -p replicapool bench $RBD_IMAGE_NAME --io-type write --io-size 8192 --io-threads 256 --io-total 10G --io-pattern seq\n",[565,689,690],{"__ignoreMap":563},[568,691,692,694,696,699,702,705,708,710,713,716,720,723,726,729,732,735],{"class":570,"line":571},[568,693,575],{"class":574},[568,695,597],{"class":578},[568,697,698],{"class":578}," -p",[568,700,701],{"class":578}," replicapool",[568,703,704],{"class":578}," bench",[568,706,707],{"class":606}," $RBD_IMAGE_NAME ",[568,709,647],{"class":578},[568,711,712],{"class":578}," write",[568,714,715],{"class":578}," --io-size",[568,717,719],{"class":718},"sbssI"," 8192",[568,721,722],{"class":578}," --io-threads",[568,724,725],{"class":718}," 256",[568,727,728],{"class":578}," --io-total",[568,730,731],{"class":578}," 10G",[568,733,734],{"class":578}," --io-pattern",[568,736,737],{"class":578}," seq\n",[678,739,741],{"id":740},"read-benchmark","Read Benchmark",[527,743,744],{},"For sequential read benchmark:",[558,746,748],{"className":560,"code":747,"language":562,"meta":563,"style":563},"$ rbd -p replicapool bench $RBD_IMAGE_NAME --io-type read --io-size 8192 --io-threads 256 --io-total 10G --io-pattern seq\n",[565,749,750],{"__ignoreMap":563},[568,751,752,754,756,758,760,762,764,766,769,771,773,775,777,779,781,783],{"class":570,"line":571},[568,753,575],{"class":574},[568,755,597],{"class":578},[568,757,698],{"class":578},[568,759,701],{"class":578},[568,761,704],{"class":578},[568,763,707],{"class":606},[568,765,647],{"class":578},[568,767,768],{"class":578}," read",[568,770,715],{"class":578},[568,772,719],{"class":718},[568,774,722],{"class":578},[568,776,725],{"class":718},[568,778,728],{"class":578},[568,780,731],{"class":578},[568,782,734],{"class":578},[568,784,737],{"class":578},[613,786,788],{"id":787},"notes","Notes",[625,790,791],{},[628,792,793,794,796,797,549],{},"To use random IO instead of sequential IO pattern, change the ",[565,795,671],{}," flag value to ",[565,798,799],{},"rand",[527,801,802],{},"Have Fun!",[804,805,806],"style",{},"html pre.shiki code .sBMFI, html code.shiki .sBMFI{--shiki-light:#E2931D;--shiki-default:#FFCB6B;--shiki-dark:#FFCB6B}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859