-file-edit-outline","\u002Fdocs\u002Fweb\u002Ftiptap","1.docs\u002Fweb\u002Ftiptap",[504],{"title":505,"path":506,"stem":507},"Snippets","\u002Fdocs\u002Fweb\u002Ftiptap\u002Fsnippets","1.docs\u002Fweb\u002Ftiptap\u002Fsnippets",{"id":509,"title":510,"authors":511,"badge":517,"body":518,"date":1461,"description":1462,"extension":1463,"image":1464,"meta":1465,"navigation":677,"path":1471,"seo":1472,"stem":1473,"__hash__":1474},"posts\u002F3.blog\u002F2017\u002Fcontainer-days-2017-hamburg.md","Container Days 2017 Hamburg",[512],{"name":513,"to":514,"avatar":515},"Alexander Trost","https:\u002F\u002Fgithub.com\u002Fgalexrt",{"src":516},"\u002Fimages\u002Fprofile-picture.jpg",null,{"type":519,"value":520,"toc":1438},"minimark",[521,526,538,557,560,564,567,572,587,594,600,603,605,609,623,629,632,634,638,641,674,680,689,691,695,708,732,748,759,820,830,849,853,861,868,879,886,903,909,917,946,958,965,969,987,989,993,996,1000,1008,1014,1017,1044,1047,1051,1054,1057,1063,1071,1077,1088,1096,1099,1106,1121,1123,1126,1130,1143,1150,1153,1156,1162,1175,1187,1194,1198,1210,1213,1219,1222,1225,1228,1239,1242,1251,1254,1260,1275,1278,1282,1294,1304,1328,1334,1345,1351,1362,1371,1375,1384,1399,1401,1405,1422,1425,1428,1434],[522,523,525],"h2",{"id":524},"thanks","Thanks!",[527,528,529,530,537],"p",{},"A huge thanks and shoutout to ",[531,532,536],"a",{"href":533,"rel":534},"https:\u002F\u002Fgithub.com\u002Fmxinden",[535],"nofollow","Max Inden @mxinden"," for having some time for a very interesting talk.",[527,539,540,544,545,550,551,556],{},[541,542,543],"strong",{},"BTW"," Checkout ",[531,546,549],{"href":547,"rel":548},"https:\u002F\u002Fcoreos.com\u002F",[535],"CoreOS","'s awesome Kubernetes ",[531,552,555],{"href":553,"rel":554},"https:\u002F\u002Fgithub.com\u002Fcoreos\u002Fprometheus-operator",[535],"prometheus-operator"," project. It is awesome for easily running Prometheus + Alertmanager in Kubernetes.",[558,559],"hr",{},[522,561,563],{"id":562},"day-1","Day #1",[527,565,566],{},"Let's see what nice things the day will bring. I hope I'll learn something new about containers and Kubernetes, and hopefully meet some new people. :-)",[568,569,571],"h3",{"id":570},"presentation-a-devops-state-of-mind-continuous-security-for-containers-with-kubernetes","Presentation: \"A DevOps State of Mind: Continuous Security for Containers with Kubernetes\"",[527,573,574,575,580,581,586],{},"The presentation of ",[531,576,579],{"href":577,"rel":578},"https:\u002F\u002Ftwitter.com\u002Fchrisvantuin",[535],"Chris van Tuin"," from ",[531,582,585],{"href":583,"rel":584},"https:\u002F\u002Fwww.redhat.com\u002Fen",[535],"Red Hat"," was very interesting for me. I'm going to attach a small diagram of what I have taken from it.",[527,588,589],{},[590,591],"img",{"alt":592,"src":593},"My own diagram of what I think was the message of Chris van Tuin from Red Hat with his presentation.","\u002Fblog\u002F2017\u002Fcontainer-days-2017-hamburg\u002Fcds2017-photo0.png",[527,595,596],{},[590,597],{"alt":598,"src":599},"Quick photo of the crowd and one of the slides of the presentation.","\u002Fblog\u002F2017\u002Fcontainer-days-2017-hamburg\u002Fcds2017-photo1.png",[527,601,602],{},"For me what counted here, was the message (see the diagram above) I got from the presentation. Interesting isn't only to write, but also to discuss about it at the conference.",[558,604],{},[568,606,608],{"id":607},"presentation-deploy-a-resilient-e-commerce-platform-using-latest-docker-tools","Presentation: \"Deploy a resilient E-commerce platform using latest docker tools\"",[527,610,611,612,580,617,622],{},"Next presentation I went to was \"Deploy a resilient E-commerce platform using latest docker tools\" of ",[531,613,616],{"href":614,"rel":615},"https:\u002F\u002Fgithub.com\u002Fxinity",[535],"Rachid Zarouali",[531,618,621],{"href":619,"rel":620},"https:\u002F\u002Fwww.synolia.com\u002F",[535],"SYNOLIA",".\nHe gave some interesting insights in their E-commerce platform, in which they weren't \"simply\" using Kubernetes. As the title from the presentation suggets, the tools used by them are mostly official Docker tools\u002Fprojects, but also some other open source projects too.",[527,624,625,628],{},[541,626,627],{},"For Kubernetes users",": Just keep on using Kubernetes ;)",[527,630,631],{},"Overall a well made presentation, as written with good insights into the tooling used. Should be interesting for everyone that has to decide between Kubernetes and Docker Swarm.",[558,633],{},[568,635,637],{"id":636},"lunch-time","Lunch Time",[527,639,640],{},"I'll just point you to my Tweet for a \"proper\" response to that:",[642,643,648,669,670],"blockquote",{"className":644,"dataLang":647},[645,646],"twitter-tweet","tw-align-center","en",[527,649,651,655,656,660,661,655,665],{"lang":647,"dir":650},"ltr",[531,652,654],{"href":653},"https:\u002F\u002Ftwitter.com\u002Fmesosphere","@mesosphere"," ",[531,657,659],{"href":658},"https:\u002F\u002Ftwitter.com\u002FConDaysEU","@ConDaysEU"," Your \"cloud\" burgers are delicious! ",[531,662,664],{"href":663},"https:\u002F\u002Ftwitter.com\u002Fhashtag\u002FCDS17?src=hash","#CDS17",[531,666,668],{"href":667},"https:\u002F\u002Ft.co\u002Fg1cpkd81rN","pic.twitter.com\u002Fg1cpkd81rN","— galexrt (@galexrt) ",[531,671,673],{"href":672},"https:\u002F\u002Ftwitter.com\u002Fgalexrt\u002Fstatus\u002F877127039479926784","June 20, 2017",[675,676],"script",{"async":677,"src":678,"charSet":679},true,"\u002F\u002Fplatform.twitter.com\u002Fwidgets.js","utf-8",[527,681,682,683,688],{},"To summarize it, the pulled pork burger I had was delicious! Good on the ",[531,684,687],{"href":685,"rel":686},"http:\u002F\u002Fbigbenburgertruck.de\u002F",[535],"Big Ben Burger Truck Hamburg"," guys for that.",[558,690],{},[568,692,694],{"id":693},"workshop-kubernetes-anywhere-production-ready-with-prometheus","Workshop: \"Kubernetes Anywhere, Production Ready with Prometheus\"",[527,696,697,698,701,702,707],{},"The workshop was held by ",[531,699,536],{"href":533,"rel":700},[535]," and ",[531,703,706],{"href":704,"rel":705},"https:\u002F\u002Fgithub.com\u002Falexsomesan",[535],"Alex Somesan",".\nI couldn't really create my own cluster on AWS for testing, as my AWS account gave me some trouble to first sort out.",[527,709,710,711,716,717,721,722,724,725,727,728,731],{},"It is very interesting to see ",[531,712,715],{"href":713,"rel":714},"https:\u002F\u002Fcoreos.com\u002Ftectonic\u002F",[535],"Tectonic"," create the cluster with such simplicity. As I already worked with the prometheus-operator there wasn't that much new I could learn about, but at least I could collect some more experience on how to better create\u002Fuse the prometheus-operator ",[718,719,720],"code",{},"ServiceMonitor","s.\nThe approach for using ",[718,723,720],{},"s the \"best\" way, is to create the least ",[718,726,720],{},"s for the most ",[718,729,730],{},"Service","s you want to monitor.",[527,733,734,737,738,741,742,747],{},[541,735,736],{},"About Tectonic",": It looks, as already written earlier, like an awesome tool for deploying Kubernetes on AWS and Bare Metal. But keep in mind, I could only try it out on AWS, but will definetly try it when I have the time to deploy Kubernets with ",[531,739,715],{"href":713,"rel":740},[535]," + ",[531,743,746],{"href":744,"rel":745},"https:\u002F\u002Fcoreos.com\u002Fmatchbox\u002F",[535],"Matchbox"," on bare-metal.",[527,749,750,751,754,755,758],{},"From the workshop I \"rediscovered\" the usage of ",[718,752,753],{},"kubectl","s subcommand ",[718,756,757],{},"port-forward",". You should definetly use it, instead of for example using the Kubernetes api directly as a (HTTP) proxy.\nAs I normally used the API proxy to access services, here the usage of the command:",[760,761,766],"pre",{"className":762,"code":763,"language":764,"meta":765,"style":765},"language-bash shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","$ kubectl port-forward POD [LOCAL_PORT:]REMOTE_PORT [...[LOCAL_PORT_N:]REMOTE_PORT_N] [options]\n","bash","",[718,767,768],{"__ignoreMap":765},[769,770,773,777,781,784,787,791,795,798,800,803,806,809,811,814,817],"span",{"class":771,"line":772},"line",1,[769,774,776],{"class":775},"sBMFI","$",[769,778,780],{"class":779},"sfazB"," kubectl",[769,782,783],{"class":779}," port-forward",[769,785,786],{"class":779}," POD",[769,788,790],{"class":789},"sTEyZ"," [LOCAL_PORT:]REMOTE_PORT ",[769,792,794],{"class":793},"sMK4o","[",[769,796,797],{"class":789},"...",[769,799,794],{"class":793},[769,801,802],{"class":789},"LOCAL_PORT_N:",[769,804,805],{"class":793},"]",[769,807,808],{"class":789},"REMOTE_PORT_N",[769,810,805],{"class":793},[769,812,813],{"class":793}," [",[769,815,816],{"class":789},"options",[769,818,819],{"class":793},"]\n",[527,821,822,823,655,826,829],{},"So all in all, the workshop was well done and brought some insights into using ",[531,824,549],{"href":547,"rel":825},[535],[531,827,715],{"href":713,"rel":828},[535]," software\u002Ftool.",[642,831,832],{},[527,833,834,837,838,842,843,848],{},[541,835,836],{},"NOTE"," For people wanting to try out the workshop of ",[531,839,841],{"href":533,"rel":840},[535],"Max Inden",", the workshop github repo with all the information is located here: ",[531,844,847],{"href":845,"rel":846},"https:\u002F\u002Fgithub.com\u002Fmxinden\u002Fk8s-anywhere-workshop",[535],"mxinden\u002Fk8s-anywhere-workshop",".",[568,850,852],{"id":851},"presentation-automating-kubernetes-cluster-operations-with-operators","Presentation: \"Automating Kubernetes Cluster Operations with Operators\"",[527,854,855,856,848],{},"Or \"Running Kubernetes in Kubernetes\".\nThis presentation was held by Timo Derstappen from ",[531,857,860],{"href":858,"rel":859},"https:\u002F\u002Fgiantswarm.io\u002F",[535],"Giant Swarm",[642,862,863],{},[527,864,865],{},[541,866,867],{},"GLOSSAR",[869,870,871],"ul",{},[872,873,874,878],"li",{},[875,876,877],"em",{},"Giantnetes"," - The \"master\" Kubernetes instance, in which the other Kubernetes clusters are started\u002Frun.",[527,880,881,882,885],{},"Use operators to run ",[541,883,884],{},"operational"," tasks from within the cluster.",[642,887,888,892],{},[527,889,890],{},[541,891,836],{},[527,893,894,895,898,899,902],{},"Kubernetes renames ",[718,896,897],{},"Third Party Resources"," to ",[718,900,901],{},"Custom Resource Definitions"," soon.",[527,904,905,908],{},[541,906,907],{},"OUTLOOK",": Using operators you can automate \"everything\" for and around the cluster.",[642,910,911],{},[527,912,913,916],{},[541,914,915],{},"EXAMPLES"," Operator examples from presenter:",[869,918,919,925,931,937,943],{},[872,920,921,924],{},[718,922,923],{},"cert-operator"," - Creates certificates for the ingresses, etc.",[872,926,927,930],{},[718,928,929],{},"kvm-operator"," - To spin up new KVM instances for the cluster(s).",[872,932,933,936],{},[718,934,935],{},"flannel-operator"," - Configures networks for Kubernetes clusters that run inside the Giantnetes.",[872,938,939,942],{},[718,940,941],{},"dns-operator"," - For external DNS provisioning.",[872,944,945],{},"And so on..",[527,947,948,949,952,953,848],{},"They also created a library\u002Fboilerplate for simple creation of Kubernetes operators.\nThe library is named ",[718,950,951],{},"operatorkit"," and written in Golang. The GitHub repo can be found here: ",[531,954,957],{"href":955,"rel":956},"https:\u002F\u002Fgithub.com\u002Fgiantswarm\u002Foperatorkit",[535],"giantswarm\u002Foperatorkit",[642,959,960],{},[527,961,962,964],{},[541,963,836],{}," They built a nice game, where you shoot Kubernetes pods.\nSeperate note originally taken from the presenter: \"We are hiring!\"",[568,966,968],{"id":967},"end-of-the-first-day","End of the first day",[527,970,971,972,974,975,978,979,982,983,986],{},"I try to summarize the day for today in a simple manner: \"Kubernetes, Security, Deploying, Automation and Beer!\".\nExtensive talks about using Kubernetes operators (aka ",[718,973,897],{},"s) to automate tasks, using ",[531,976,715],{"href":713,"rel":977},[535]," to create Kubernetes clusters and especially the ",[531,980,555],{"href":553,"rel":981},[535]," for automating the monitoring in a cluster from the workshop from ",[531,984,536],{"href":533,"rel":985},[535],".\nThe day was fun, the workshop was good, the lunch was deliciois and overall everybody had fun.",[558,988],{},[522,990,992],{"id":991},"day-2","Day #2",[527,994,995],{},"Yesterday was a good day. Some new interesting concepts about running containers, not only in Kubernetes but also using \"native\" Docker tools, have been shown.",[568,997,999],{"id":998},"presentation-meet-kubo-bosh-powered-kubernetes-cluster","Presentation: \"Meet Kubo: BOSH-Powered Kubernetes Cluster\"",[527,1001,1002,1003,848],{},"The presentation was held by Ulrich Hoelscher from ",[531,1004,1007],{"href":1005,"rel":1006},"https:\u002F\u002Ftwitter.com\u002FDellEMC",[535],"Dell EMC",[527,1009,1010],{},[590,1011],{"alt":1012,"src":1013},"The slide showed the 'inheritance' from BORG.","\u002Fblog\u002F2017\u002Fcontainer-days-2017-hamburg\u002Fcds2017-photo2.png",[527,1015,1016],{},"No offense against the presentator, maybe it was just the lack of me drinking a coffee before going to the tlak, but in the end it sounded like \"Kubernetes, Containers, VMs, Pivotal Cloud Foundry does the thing\".",[642,1018,1019,1023,1026,1030],{},[527,1020,1021],{},[541,1022,836],{},[527,1024,1025],{},"Aren't we all companies that want to sell our products? ;)",[527,1027,1028],{},[541,1029,836],{},[527,1031,1032,1033,1036,1037,701,1040,1043],{},"The speaker said that Google recommends seperate Kubernetes clusters per stage aka ",[875,1034,1035],{},"Dev",", ",[875,1038,1039],{},"QA",[875,1041,1042],{},"Live"," cluster.",[527,1045,1046],{},"Overall it was interesting what BOSH with Kubo has to offer for running Kubernetes in the cloud.\nFor me it wasn't that interesting, as I'm looking for a tool that works on bare-metal and not only in the cloud from a specific provider. BOSH may even work with bare-metal too, but it doesn't seem like it as he mentioned the usage of cloud loadbalancers for HTTP and TCP services, and cloud provider API(s) for creating VMs for the cluster.",[568,1048,1050],{"id":1049},"presentation-containerops-using-kubernetes-to-orchestrate-devops-workflow","Presentation: \"ContainerOps - Using Kubernetes to Orchestrate DevOps Workflow\"",[527,1052,1053],{},"The presentation was held by Zhen Ju from Huawei.",[527,1055,1056],{},"He talked about the DevOps story, DevOps Workflow Orechestration and the lifecycle of DevOps.\nIt would be best, to just take a look at his slides to get a good impression on what he talked about.",[527,1058,1059],{},[590,1060],{"alt":1061,"src":1062},"Another diagram that showed a DevOps flow for building applications.","\u002Fblog\u002F2017\u002Fcontainer-days-2017-hamburg\u002Fcds2017-photo3.png",[527,1064,1065,1066,848],{},"He mentioned their baseimage that solves the issues with some existing baseimages, like lightweighness of the image, process reaping, etc.\nIt is availabe on GitHub: ",[531,1067,1070],{"href":1068,"rel":1069},"https:\u002F\u002Fgithub.com\u002Fphusion\u002Fbaseimage-docker",[535],"phusion\u002Fbaseimage-docker",[527,1072,1073],{},[590,1074],{"alt":1075,"src":1076},"Even though the quality of the pictures seem to get worse from picture to picture. The slide contained an interesting diagram of an 'example' DevOps Orchestration Workflow.","\u002Fblog\u002F2017\u002Fcontainer-days-2017-hamburg\u002Fcds2017-photo4.png",[642,1078,1079,1085],{},[527,1080,1081,1084],{},[541,1082,1083],{},"QUOTE"," from Zhen Ju:",[527,1086,1087],{},"\"With Container, For Container\"",[527,1089,1090,1091,848],{},"Their project for simplifying\u002Fsimpler DevOps is located on GitHub, here: ",[531,1092,1095],{"href":1093,"rel":1094},"https:\u002F\u002Fgithub.com\u002FHuawei\u002FcontainerOps",[535],"Huawei\u002FcontainerOps",[568,1097,637],{"id":1098},"lunch-time-1",[527,1100,1101,1102,1105],{},"This time, I'll have to point you to a tweet from ",[531,1103,659],{"href":658,"rel":1104},[535],":",[642,1107,1109,1116,1117],{"className":1108,"dataLang":647},[645,646],[527,1110,1111,1112],{"lang":647,"dir":650},"No words necessary! ",[531,1113,1115],{"href":1114},"https:\u002F\u002Ft.co\u002Fas8SC7aWIS","pic.twitter.com\u002Fas8SC7aWIS","— ContainerDays (@ConDaysEU) ",[531,1118,1120],{"href":1119},"https:\u002F\u002Ftwitter.com\u002FConDaysEU\u002Fstatus\u002F877463813548896256","June 21, 2017",[675,1122],{"async":677,"src":678,"charSet":679},[527,1124,1125],{},"I ate the burger instead of the falafel, but at least for the burger I can confirm that they were still as delicious as yesterday!",[568,1127,1129],{"id":1128},"presentation-ship-your-containers-fast-with-gitlabci","Presentation: \"Ship your containers fast with GitLab\u002FCI\"",[527,1131,1132,1133,580,1138,848],{},"The presentation was held by ",[531,1134,1137],{"href":1135,"rel":1136},"https:\u002F\u002Fgithub.com\u002Fsolidnerd",[535],"Niclas Mietz",[531,1139,1142],{"href":1140,"rel":1141},"https:\u002F\u002Fbee42.com\u002F",[535],"Bee42",[527,1144,1145,1146,1149],{},"It depends heavily on your decision on \"where\" you want to run the GitLab CI runner. The GitLab CI runner will run the given Docker images and the commands to in the end build your project.\nAlthough creating the process\u002Fpipeline(s) for a project isn't that hard as it might seem. If you are already using Docker to build your project it will be very simple to switch to using GitLab CI pipelines. It's almost as easy as simply putting the commands used to create\u002Fcompile\u002Fbuild and later on test your project into a ",[718,1147,1148],{},".gitlab-ci.yaml"," file.\nGitLab automatically detects if the CI file exists and will then show you the status of the run\u002Frunning build next to the commit(s).",[527,1151,1152],{},"Running \"Docker in Docker\" is also an option for going for fully reproducible Docker image builds.",[527,1154,1155],{},"The pipelines of GitLab CI allow for simple triggering of deployments to specific stages by a button push.\nThe deployment process has some integration possibilities, for example automatically adding Kubernetes Token, Certificate, etc. to the runner container to make the deployment to Kubernetes simpler.",[527,1157,1158],{},[590,1159],{"alt":1160,"src":1161},"The slide originally showed the example build flow using GitLab CI.","\u002Fblog\u002F2017\u002Fcontainer-days-2017-hamburg\u002Fcds2017-photo5.png",[527,1163,1164,1165,1170,1171,1174],{},"An interesting point he brought up was the use of the ",[531,1166,1169],{"href":1167,"rel":1168},"https:\u002F\u002Fgithub.com\u002Fbitnami\u002Fminideb",[535],"bitnami\u002Fminideb"," image. The ",[531,1172,1169],{"href":1167,"rel":1173},[535]," image uses glibc instead of like for example Alpine the musl library. That makes it better compatible\u002F usable for \"older\"\u002F existing applications.",[527,1176,1177,1178,1181,1182,848],{},"The first part of the GitLab CI tutorial can be found at the blog of ",[531,1179,1142],{"href":1140,"rel":1180},[535]," here: ",[531,1183,1186],{"href":1184,"rel":1185},"https:\u002F\u002Fbee42.com\u002Fblog\u002Fgetting-started-with-gitlab-part1\u002F",[535],"Bee42 - Getting Started with GitLab CI with Containers (Part 1)",[527,1188,1189,1190,1193],{},"To summarize this presentation, it showed how simple it is how to use the GitLab CI to create pipelines for your projects. For more see the link to ",[531,1191,1142],{"href":1140,"rel":1192},[535]," blog above.",[568,1195,1197],{"id":1196},"presentation-monitoring-and-logging-in-wonderland","Presentation: \"Monitoring and Logging in Wonderland\"",[527,1199,1132,1200,580,1205,848],{},[531,1201,1204],{"href":1202,"rel":1203},"https:\u002F\u002Ftwitter.com\u002FSeiffertP",[535],"Paul Seiffert",[531,1206,1209],{"href":1207,"rel":1208},"https:\u002F\u002Fwww.jimdo.com\u002F",[535],"Jimdo",[527,1211,1212],{},"First of all, I have to admit \"Wunderland\" is an interesting name for such a PaaS platform.",[527,1214,1215],{},[590,1216],{"alt":1217,"src":1218},"The photo contains a slide with the layers in which Wonderland works\u002Fbegins.","\u002Fblog\u002F2017\u002Fcontainer-days-2017-hamburg\u002Fcds2017-photo6.png",[527,1220,1221],{},"Wonderland manages the infrastructure, from loadbalancers to the containers the applications run in.",[527,1223,1224],{},"For the monitoring, they utilize their Grafana to automatically create dashboard for every service, they are running.",[527,1226,1227],{},"They have the following differenciation between metrics. It is like this:",[869,1229,1230,1233,1236],{},[872,1231,1232],{},"Application - Actual metrics from the application running.",[872,1234,1235],{},"System - Metrics from the Servers\u002FHosts\u002FVMs running.",[872,1237,1238],{},"Infrastructure - Metrics about AWS loadbalancers, etc.",[527,1240,1241],{},"..metrics.",[642,1243,1244,1248],{},[527,1245,1246],{},[541,1247,836],{},[527,1249,1250],{},"I would even go so far as to add a \"Cloud\" in front of the \"Infrastructure metrics\" in the case of using a Cloud provider.",[527,1252,1253],{},"To gather all application metrics running in volatile containers on different hosts. The Wonderland Service Discovery is used to discover services for the Prometheus monitoring.\nAn important aspect for metrics is the retention. They use so called \"recording rules\" for Prometheus. These \"recording rules\" are automatically created by a self written application to pre-aggregate certain metrics automatically and directly.",[527,1255,1256],{},[590,1257],{"alt":1258,"src":1259},"The photo contains a slide with the differenciation between short- and long term storage of metrics with Prometheus federation. In their case short term ~30 min and long term 32 days.","\u002Fblog\u002F2017\u002Fcontainer-days-2017-hamburg\u002Fcds2017-photo7.png",[527,1261,1262,1263,1268,1269,1274],{},"For analyzing logs in case of issues, they simply use ",[531,1264,1267],{"href":1265,"rel":1266},"https:\u002F\u002Fwww.elastic.co\u002Fproducts\u002Fbeats\u002Ffilebeat",[535],"Logbeat\u002FFilebeat"," for the shipping of logs and ",[531,1270,1273],{"href":1271,"rel":1272},"https:\u002F\u002Fwww.elastic.co\u002Fproducts\u002Fkibana",[535],"Kibana"," for visualizing the logs.",[527,1276,1277],{},"An interesting presentation about their own infrastructure. It shows exactly some points that are a problem for not only them, but for everyone. Good to see how they have solved the issues. That gives everyone a good idea\u002Fconcepts that may be altered\u002Fused to fit for their own case\u002Fproblem.",[568,1279,1281],{"id":1280},"presentation-operating-microservices-with-nomad-and-consul","Presentation: \"Operating Microservices with Nomad and Consul\"",[527,1283,1132,1284,580,1289,848],{},[531,1285,1288],{"href":1286,"rel":1287},"https:\u002F\u002Ftwitter.com\u002Fspanneberg",[535],"Bastian Spanneberg",[531,1290,1293],{"href":1291,"rel":1292},"https:\u002F\u002Fwww.instana.com\u002F",[535],"Instana",[642,1295,1296,1301],{},[527,1297,1298],{},[541,1299,1300],{},"DISCLAIMER",[527,1302,1303],{},"I got to the presentation a bit late. I got there at the begining of the well made demo.",[527,1305,1306,1307,1312,1313,580,1318,1323,1324,1327],{},"From what I still saw, ",[531,1308,1311],{"href":1309,"rel":1310},"https:\u002F\u002Fwww.nomadproject.io\u002F",[535],"Nomad"," looks very interesting as it seems to seamlessly integrate with ",[531,1314,1317],{"href":1315,"rel":1316},"https:\u002F\u002Fwww.consul.io\u002F",[535],"Consul",[531,1319,1322],{"href":1320,"rel":1321},"https:\u002F\u002Fwww.hashicorp.com",[535],"Hashicorp",", and run jobs in combination with Consul health checks quite well.\n",[531,1325,1288],{"href":1286,"rel":1326},[535]," showed the ease of the Consul API with some usage examples for his demo:",[527,1329,1330],{},[590,1331],{"alt":1332,"src":1333},"The slide with the Consul usage for his demo.","\u002Fblog\u002F2017\u002Fcontainer-days-2017-hamburg\u002Fcds2017-photo8.png",[527,1335,1336,1337,1340,1341,1344],{},"It was interesting to see how easy it is to run containers with ",[531,1338,1311],{"href":1309,"rel":1339},[535],". The ",[531,1342,1317],{"href":1315,"rel":1343},[535]," \"service\" manifests have an interesting, human-readable format too, which makes it easy like with the YAML manifests from Kubernetes, Docker Swarm and so on.",[527,1346,1347],{},[590,1348],{"alt":1349,"src":1350},"Who would have thought it, in the end somebody asked about the nice UI he showed. It was the Instana monitoring tool. Seems like a decent tool for monitoring and going further with tracing and everything done automatically. Just checkout their page here: https:\u002F\u002Fwww.instana.com\u002F.","\u002Fblog\u002F2017\u002Fcontainer-days-2017-hamburg\u002Fcds2017-photo9.png",[527,1352,1353,1354,1357,1358,1361],{},"A solid presentation with a nice demonstration of \"everything\" that was talked about. Now I would definetly take a closer look at ",[531,1355,1311],{"href":1309,"rel":1356},[535]," as a container runner, especially when comparing container \"runner\" (not orchestrators, see NOTE below), and ",[531,1359,1317],{"href":1315,"rel":1360},[535]," as a Key\u002FValue storage with a twist.",[642,1363,1364,1368],{},[527,1365,1366],{},[541,1367,836],{},[527,1369,1370],{},"He stated that Nomad currently doesn't have \"real\" orchestration capabilities aka you would need to write tooling around it for orchestration.",[568,1372,1374],{"id":1373},"end-of-the-second-day","End of the second day",[642,1376,1377,1381],{},[527,1378,1379],{},[541,1380,1083],{},[527,1382,1383],{},"\"The sun is slowly turning its back to us. We will wait for the comeback in the morning.\"",[527,1385,1386,1387,1392,1393,1398],{},"From what I've heard from ",[531,1388,1391],{"href":1389,"rel":1390},"https:\u002F\u002Ftwitter.com\u002FJu4444",[535],"Julian Hansert",", most feedback was good and that new ideas to continue to improve the conference were given and will actively be added with best knowledge to it, to make the conference even better or as Trump would say: ",[531,1394,1397],{"href":1395,"rel":1396},"http:\u002F\u002Fjungle.horse\u002F?jungle=The+best+conference.#%7B%22s%22%3A%22i%20have%20conferences%2C%20but%20container%20days%20has%20the%20best%20container%20conference!%22%7D",[535],"Text to Trump - Jungle.horse",".\nIt was quite a nice day again, but I would say the wind was a bit stronger today.",[558,1400],{},[522,1402,1404],{"id":1403},"summary","Summary",[527,1406,1407,1410,1411,1414,1415,1418,1419,848],{},[541,1408,1409],{},"But even the stronger winds"," didn't stop us, the attendants, to stop talking about containers and how we, for ourselves, ",[541,1412,1413],{},"can maneuver"," through the ",[541,1416,1417],{},"strong streams"," of the many different container projects, tools and orchestrators to find us the ",[541,1420,1421],{},"perfect fitting tool for the job",[527,1423,1424],{},"I for my part have one thing I would change, but for myself, that I should bring a phone with a more stable camera API or b) bring a seperate good camera for taking photos at the conference, so the photos have a better quality than the potato like ones right now.",[527,1426,1427],{},"I hope everybody had fun and learned something new. I hope to stay in touch with the cool people I met there and see them soon at another conference or meetup. :-)\nHave Fun!",[527,1429,1430,1433],{},[541,1431,1432],{},"P.S.",": Please let me know (by comment or email), if there is anything I can improve to make this post about the conference even better. Thanks for reading!",[1435,1436,1437],"style",{},"html pre.shiki code .sBMFI, html code.shiki .sBMFI{--shiki-light:#E2931D;--shiki-default:#FFCB6B;--shiki-dark:#FFCB6B}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859;--shiki-default:#C3E88D;--shiki-dark:#C3E88D}html pre.shiki code .sTEyZ, html code.shiki .sTEyZ{--shiki-light:#90A4AE;--shiki-default:#EEFFFF;--shiki-dark:#BABED8}html pre.shiki code .sMK4o, html code.shiki .sMK4o{--shiki-light:#39ADB5;--shiki-default:#89DDFF;--shiki-dark:#89DDFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}",{"title":765,"searchDepth":1439,"depth":1439,"links":1440},2,[1441,1442,1451,1460],{"id":524,"depth":1439,"text":525},{"id":562,"depth":1439,"text":563,"children":1443},[1444,1446,1447,1448,1449,1450],{"id":570,"depth":1445,"text":571},3,{"id":607,"depth":1445,"text":608},{"id":636,"depth":1445,"text":637},{"id":693,"depth":1445,"text":694},{"id":851,"depth":1445,"text":852},{"id":967,"depth":1445,"text":968},{"id":991,"depth":1439,"text":992,"children":1452},[1453,1454,1455,1456,1457,1458,1459],{"id":998,"depth":1445,"text":999},{"id":1049,"depth":1445,"text":1050},{"id":1098,"depth":1445,"text":637},{"id":1128,"depth":1445,"text":1129},{"id":1196,"depth":1445,"text":1197},{"id":1280,"depth":1445,"text":1281},{"id":1373,"depth":1445,"text":1374},{"id":1403,"depth":1439,"text":1404},"2017-06-20T11:23:08+02:00","Some thoughts, notes, comments and pictures from the Container Days 2017 in Hamburg.","md",{"src":599},{"tags":1466},[1467,1468,1469,1470,124],"Conferences","ContainerDays","Container","Docker","\u002Fblog\u002F2017\u002Fcontainer-days-2017-hamburg",{"title":510,"description":1462},"3.blog\u002F2017\u002Fcontainer-days-2017-hamburg","eBgYquKXAUcmqaX-Ft2TPB8EotviDzO7w9HYJZPLrZI",[1476,1481],{"title":1477,"path":1478,"stem":1479,"description":1480,"children":-1},"Ceph: rbd bench Commands","\u002Fblog\u002F2017\u002Fceph-rbd-bench-commands","3.blog\u002F2017\u002Fceph-rbd-bench-commands","Commands for running rbd bench(marks).",{"title":1482,"path":1483,"stem":1484,"description":1485,"children":-1},"Container Linux: Deploy on Bare-Metal without DHCP server","\u002Fblog\u002F2017\u002Fcontainer-linux-deploy-on-bare-metal-without-dhcp-server","3.blog\u002F2017\u002Fcontainer-linux-deploy-on-bare-metal-without-dhcp-server","This is more of a quick writeup in form of a note on how to deploy Container Linux on bare-metal without DHCP server.",1776977684703]