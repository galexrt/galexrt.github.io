","\u002Fdocs\u002Fweb\u002Ftiptap","1.docs\u002Fweb\u002Ftiptap",[504],{"title":505,"path":506,"stem":507},"Snippets","\u002Fdocs\u002Fweb\u002Ftiptap\u002Fsnippets","1.docs\u002Fweb\u002Ftiptap\u002Fsnippets",{"id":509,"title":510,"authors":511,"badge":511,"body":512,"date":1024,"description":1025,"extension":1026,"image":1027,"meta":1029,"navigation":1033,"path":1034,"seo":1035,"stem":1036,"__hash__":1037},"posts\u002F3.blog\u002F2016\u002Fzulip-installation.md","Zulip: Installation",null,{"type":513,"value":514,"toc":1010},"minimark",[515,526,529,534,545,554,558,568,571,601,608,612,615,628,635,654,660,663,722,737,740,744,747,755,764,767,771,774,787,791,797,800,846,849,853,856,875,878,894,903,906,913,939,942,946,949,952,962,965,969,974,977,993,995,998,1006],[516,517,518],"blockquote",{},[519,520,521,525],"p",{},[522,523,524],"strong",{},"Please note",": This post is more of a \"draft\" that may not be on my level of post quality.",[519,527,528],{},"Zulip is a powerful open source group chat able to handle multi channel communications. It runs on python.",[530,531,533],"h2",{"id":532},"requirements","Requirements",[519,535,536,537,541,542,544],{},"An Ubuntu Server with at least ",[538,539,540],"code",{},"2GB"," of RAM (",[538,543,540],{}," RAM is currently the recommended amount for a small site).\nMy example server for this tutorial has the following address:",[546,547,548],"ul",{},[549,550,551],"li",{},[538,552,553],{},"203.0.113.1 zulip-tutorial-example",[530,555,557],{"id":556},"preparing-your-server-for-zulip","Preparing your server for Zulip",[516,559,560,565],{},[519,561,562],{},[522,563,564],{},"NOTE",[519,566,567],{},"The current Zulip installation deployment uses one full server! The deployment doesn't care about other services on the server.",[519,569,570],{},"Make sure your server is at the latest version before continuing with the\nTo update all packages on Ubuntu run:",[572,573,578],"pre",{"className":574,"code":575,"language":576,"meta":577,"style":577},"language-bash shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","apt-get update\napt-get upgrade\n","bash","",[538,579,580,593],{"__ignoreMap":577},[581,582,585,589],"span",{"class":583,"line":584},"line",1,[581,586,588],{"class":587},"sBMFI","apt-get",[581,590,592],{"class":591},"sfazB"," update\n",[581,594,596,598],{"class":583,"line":595},2,[581,597,588],{"class":587},[581,599,600],{"class":591}," upgrade\n",[519,602,603,604,607],{},"Confirm with (depending on the system locale) with ",[538,605,606],{},"y",".`",[530,609,611],{"id":610},"step-1-downloading-zulip","Step 1 - Downloading Zulip",[519,613,614],{},"Please login as root user.\nOn most Ubuntu systems, you would use",[572,616,618],{"className":574,"code":617,"language":576,"meta":577,"style":577},"sudo -i\n",[538,619,620],{"__ignoreMap":577},[581,621,622,625],{"class":583,"line":584},[581,623,624],{"class":587},"sudo",[581,626,627],{"class":591}," -i\n",[519,629,630,631,634],{},"to switch to the root user.\nNext up we make sure that we are in the root user's home directory ",[538,632,633],{},"\u002Froot",".",[572,636,638],{"className":574,"code":637,"language":576,"meta":577,"style":577},"cd \u002Froot\npwd\n",[538,639,640,649],{"__ignoreMap":577},[581,641,642,646],{"class":583,"line":584},[581,643,645],{"class":644},"s2Zo4","cd",[581,647,648],{"class":591}," \u002Froot\n",[581,650,651],{"class":583,"line":595},[581,652,653],{"class":644},"pwd\n",[519,655,656,659],{},[538,657,658],{},"pwd"," prints the current working directoy.",[519,661,662],{},"For the latest Zulip version the download and extraction commands are:",[572,664,666],{"className":574,"code":665,"language":576,"meta":577,"style":577},"cd \u002Froot\nwget https:\u002F\u002Fwww.zulip.com\u002Fdist\u002Freleases\u002Fzulip-server-latest.tar.gz\nrm -rf \u002Froot\u002Fzulip && mkdir \u002Froot\u002Fzulip\ntar -xf zulip-server-latest.tar.gz --directory=\u002Froot\u002Fzulip --strip-components=1\n",[538,667,668,674,682,704],{"__ignoreMap":577},[581,669,670,672],{"class":583,"line":584},[581,671,645],{"class":644},[581,673,648],{"class":591},[581,675,676,679],{"class":583,"line":595},[581,677,678],{"class":587},"wget",[581,680,681],{"class":591}," https:\u002F\u002Fwww.zulip.com\u002Fdist\u002Freleases\u002Fzulip-server-latest.tar.gz\n",[581,683,685,688,691,694,698,701],{"class":583,"line":684},3,[581,686,687],{"class":587},"rm",[581,689,690],{"class":591}," -rf",[581,692,693],{"class":591}," \u002Froot\u002Fzulip",[581,695,697],{"class":696},"sMK4o"," &&",[581,699,700],{"class":587}," mkdir",[581,702,703],{"class":591}," \u002Froot\u002Fzulip\n",[581,705,707,710,713,716,719],{"class":583,"line":706},4,[581,708,709],{"class":587},"tar",[581,711,712],{"class":591}," -xf",[581,714,715],{"class":591}," zulip-server-latest.tar.gz",[581,717,718],{"class":591}," --directory=\u002Froot\u002Fzulip",[581,720,721],{"class":591}," --strip-components=1\n",[516,723,724,728],{},[519,725,726],{},[522,727,564],{},[519,729,730,731,733,734,736],{},"You need to have ",[538,732,709],{}," and ",[538,735,678],{}," installed on the server. On most servers these tools are already installed.",[519,738,739],{},"Now that we have Zulip downloaded, we can continue to the next step.",[530,741,743],{"id":742},"step-2-install-zulip","Step 2 - Install Zulip",[519,745,746],{},"With the following command, we start the Zulip installation.",[516,748,749],{},[519,750,751,754],{},[522,752,753],{},"!! WARNING !!"," This will install Zulip to your server and if other applications are also running on this server it can completely mess them up, as mentioned earlier!",[572,756,758],{"className":574,"code":757,"language":576,"meta":577,"style":577},"\u002Froot\u002Fzulip\u002Fscripts\u002Fsetup\u002Finstall\n",[538,759,760],{"__ignoreMap":577},[581,761,762],{"class":583,"line":584},[581,763,757],{"class":587},[519,765,766],{},"The command may take some to complete. The command installs Zulip's dependencies and Zulip itself on the server.",[530,768,770],{"id":769},"step-3-checking-the-zulip-installation","Step 3 - Checking the Zulip installation",[519,772,773],{},"Navigate to the bottom of the file and check that it reports the success of the installation.\nThe command for opening the installation log file in a \"paginator\" is:",[572,775,777],{"className":574,"code":776,"language":576,"meta":577,"style":577},"less \u002Fvar\u002Flog\u002Fzulip\u002Finstall.log\n",[538,778,779],{"__ignoreMap":577},[581,780,781,784],{"class":583,"line":584},[581,782,783],{"class":587},"less",[581,785,786],{"class":591}," \u002Fvar\u002Flog\u002Fzulip\u002Finstall.log\n",[530,788,790],{"id":789},"step-4-configuring-the-zulip-instance","Step 4 - Configuring the Zulip instance",[519,792,793,794,634],{},"For Zulip to function you need to set some mandatory settings.\nZulip's config file is located at ",[538,795,796],{},"\u002Fetc\u002Fzulip\u002Fsettings.py",[519,798,799],{},"The following list contains the mandatory settings.",[546,801,802,808,814,819,825,831,837],{},[549,803,804,807],{},[538,805,806],{},"EXTERNAL_HOST"," should be your external address.",[549,809,810,813],{},[538,811,812],{},"ZULIP_ADMINISTRATOR"," the email of the administrator that will be also shown as the contact email address.",[549,815,816],{},[538,817,818],{},"AUTHENTICATION_BACKENDS",[549,820,821,824],{},[538,822,823],{},"EMAIL_*"," the email server settings, please look at the comments in the file for more information about the variables.",[549,826,827,830],{},[538,828,829],{},"DEFAULT_FROM_EMAIL"," the default sender email address used for the outgoing email traffic.",[549,832,833,836],{},[538,834,835],{},"NOREPLY_EMAIL_ADDRESS"," the address for noreply in the outgoing email traffic.",[549,838,839,842,843,634],{},[538,840,841],{},"ALLOWED_HOSTS"," the fully qualified DNS name of the server you installed Zulip on or just set it to ",[538,844,845],{},"*",[519,847,848],{},"The config file contains a comment above all the variables.\nGo ahead and configure the mandatory values to your needs.",[530,850,852],{"id":851},"step-5-preparing-the-zulip-instance-for-usage","Step 5 - Preparing the Zulip instance for usage",[519,854,855],{},"Now that you have Zulip configured, we can now initialize the database.",[572,857,859],{"className":574,"code":858,"language":576,"meta":577,"style":577},"su zulip -c \u002Fhome\u002Fzulip\u002Fdeployments\u002Fcurrent\u002Fscripts\u002Fsetup\u002Finitialize-database\n",[538,860,861],{"__ignoreMap":577},[581,862,863,866,869,872],{"class":583,"line":584},[581,864,865],{"class":587},"su",[581,867,868],{"class":591}," zulip",[581,870,871],{"class":591}," -c",[581,873,874],{"class":591}," \u002Fhome\u002Fzulip\u002Fdeployments\u002Fcurrent\u002Fscripts\u002Fsetup\u002Finitialize-database\n",[519,876,877],{},"After the database initialization has successfully completed, we should now you should verify that your Zulip email settings are correct:",[572,879,881],{"className":574,"code":880,"language":576,"meta":577,"style":577},".\u002Fmanage.py send_test_email YOUR_EMAIL_ADDRESS\n",[538,882,883],{"__ignoreMap":577},[581,884,885,888,891],{"class":583,"line":584},[581,886,887],{"class":587},".\u002Fmanage.py",[581,889,890],{"class":591}," send_test_email",[581,892,893],{"class":591}," YOUR_EMAIL_ADDRESS\n",[516,895,896,900],{},[519,897,898],{},[522,899,564],{},[519,901,902],{},"Replace the placeholders with your own values.",[519,904,905],{},"The command above will send a test email to the specified email address, please make sure the email successfully arrives.\nIf it's not in the inbox make sure to also check your SPAM folder.",[519,907,908,909,912],{},"We need a Zulip organistation for your users.\nFor that we need to switch to the ",[538,910,911],{},"zulip"," user, switch into the current Zulip installation and create a link for realm generation with the command:",[572,914,916],{"className":574,"code":915,"language":576,"meta":577,"style":577},"su zulip\ncd \u002Fhome\u002Fzulip\u002Fdeployments\u002Fcurrent\n.\u002Fmanage.py generate_realm_creation_link\n",[538,917,918,925,932],{"__ignoreMap":577},[581,919,920,922],{"class":583,"line":584},[581,921,865],{"class":587},[581,923,924],{"class":591}," zulip\n",[581,926,927,929],{"class":583,"line":595},[581,928,645],{"class":644},[581,930,931],{"class":591}," \u002Fhome\u002Fzulip\u002Fdeployments\u002Fcurrent\n",[581,933,934,936],{"class":583,"line":684},[581,935,887],{"class":587},[581,937,938],{"class":591}," generate_realm_creation_link\n",[519,940,941],{},"Go to the link the last command outputs and you will be prompted with a form for an account and realm creation.\nA realm is like an organization.",[530,943,945],{"id":944},"step-6-using-your-zulip-instance","Step 6 - Using your Zulip instance",[519,947,948],{},"Now just navigate to your Zulip instance and if you need to login go ahead.",[519,950,951],{},"You now have a working Zulip instance!",[519,953,954,955,634],{},"If you want to read more about configuration and the integration possibilities you can go to the official documentation of Zulip.\nSee ",[956,957,961],"a",{"href":958,"rel":959},"https:\u002F\u002Fzulip.readthedocs.io\u002Fen\u002Flatest\u002Findex.html",[960],"nofollow","Zulip Official Documentation",[963,964],"hr",{},[530,966,968],{"id":967},"tips-and-tricks","Tips and Tricks",[970,971,973],"h3",{"id":972},"restarting-zulip","Restarting Zulip",[519,975,976],{},"Use the below command to restart your Zulip instance, after making changes to the config:",[572,978,980],{"className":574,"code":979,"language":576,"meta":577,"style":577},"su zulip -c \u002Fhome\u002Fzulip\u002Fdeployments\u002Fcurrent\u002Fscripts\u002Frestart-server\n",[538,981,982],{"__ignoreMap":577},[581,983,984,986,988,990],{"class":583,"line":584},[581,985,865],{"class":587},[581,987,868],{"class":591},[581,989,871],{"class":591},[581,991,992],{"class":591}," \u002Fhome\u002Fzulip\u002Fdeployments\u002Fcurrent\u002Fscripts\u002Frestart-server\n",[963,994],{},[530,996,207],{"id":997},"troubleshooting",[519,999,1000,1001,634],{},"A good guide for troubleshooting can be found on the official documentation of Zulip ",[956,1002,1005],{"href":1003,"rel":1004},"https:\u002F\u002Fzulip.readthedocs.io\u002Fen\u002Flatest\u002Fprod-troubleshooting.html",[960],"here",[1007,1008,1009],"style",{},"html pre.shiki code .sBMFI, html code.shiki .sBMFI{--shiki-light:#E2931D;--shiki-default:#FFCB6B;--shiki-dark:#FFCB6B}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859;--shiki-default:#C3E88D;--shiki-dark:#C3E88D}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html pre.shiki code .s2Zo4, html code.shiki .s2Zo4{--shiki-light:#6182B8;--shiki-default:#82AAFF;--shiki-dark:#82AAFF}html pre.shiki code .sMK4o, html code.shiki .sMK4o{--shiki-light:#39ADB5;--shiki-default:#89DDFF;--shiki-dark:#89DDFF}",{"title":577,"searchDepth":595,"depth":595,"links":1011},[1012,1013,1014,1015,1016,1017,1018,1019,1020,1023],{"id":532,"depth":595,"text":533},{"id":556,"depth":595,"text":557},{"id":610,"depth":595,"text":611},{"id":742,"depth":595,"text":743},{"id":769,"depth":595,"text":770},{"id":789,"depth":595,"text":790},{"id":851,"depth":595,"text":852},{"id":944,"depth":595,"text":945},{"id":967,"depth":595,"text":968,"children":1021},[1022],{"id":972,"depth":684,"text":973},{"id":997,"depth":595,"text":207},"2016-09-14T09:23:42+02:00","A tutorial that guides you through installing Zulip.","md",{"src":1028},"\u002Fblog\u002F2016\u002Fzulip-installation\u002Fzulip-icon-512x512.png",{"tags":1030},[1031,1032],"Zulip","Installation",true,"\u002Fblog\u002F2016\u002Fzulip-installation",{"title":510,"description":1025},"3.blog\u002F2016\u002Fzulip-installation","9VcR-miX2pQW1CB6riV85QIABaLE2Q00ZShzTwinuVI",[1039,1044],{"title":1040,"path":1041,"stem":1042,"description":1043,"children":-1},"SteamCMD: Not working on CephFS","\u002Fblog\u002F2016\u002Fsteamcmd-not-working-on-cephfs","3.blog\u002F2016\u002Fsteamcmd-not-working-on-cephfs","A small and uncomplete analysis of why the SteamCMD is not working on CephFS.",{"title":1045,"path":1046,"stem":1047,"description":1048,"children":-1},"Ceph: rbd bench Commands","\u002Fblog\u002F2017\u002Fceph-rbd-bench-commands","3.blog\u002F2017\u002Fceph-rbd-bench-commands","Commands for running rbd bench(marks).",1776935001186]