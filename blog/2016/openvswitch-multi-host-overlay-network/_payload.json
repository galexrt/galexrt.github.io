e":22},"Tiptap","i-mdi-file-edit-outline","\u002Fdocs\u002Fweb\u002Ftiptap","1.docs\u002Fweb\u002Ftiptap",[504],{"title":505,"path":506,"stem":507},"Snippets","\u002Fdocs\u002Fweb\u002Ftiptap\u002Fsnippets","1.docs\u002Fweb\u002Ftiptap\u002Fsnippets",{"id":509,"title":510,"authors":511,"badge":517,"body":518,"date":1414,"description":1415,"extension":1416,"image":1417,"meta":1419,"navigation":1422,"path":1423,"seo":1424,"stem":1425,"__hash__":1426},"posts\u002F3.blog\u002F2016\u002Fopenvswitch-multi-host-overlay-network.md","OpenVSwitch: Multi-Host Overlay Network",[512],{"name":513,"to":514,"avatar":515},"Alexander Trost","https:\u002F\u002Fgithub.com\u002Fgalexrt",{"src":516},"\u002Fimages\u002Fprofile-picture.jpg",null,{"type":519,"value":520,"toc":1402},"minimark",[521,543,548,551,555,579,583,586,589,593,602,608,632,647,662,665,675,679,682,698,715,827,831,834,872,875,882,885,905,911,939,943,946,958,965,1029,1036,1091,1098,1151,1155,1162,1182,1191,1197,1241,1246,1270,1273,1277,1287,1299,1314,1325,1343,1346,1372,1385,1388,1392,1395,1398],[522,523,524,531],"blockquote",{},[525,526,527],"p",{},[528,529,530],"strong",{},"NOTE",[525,532,533,534,538,539,542],{},"This tutorial is written for Fedora but can be applied to all rhel based systems.\nThe only \"big\" thing you would need to change is the package manager command from ",[535,536,537],"code",{},"dnf"," to for example ",[535,540,541],{},"yum",".",[544,545,547],"h2",{"id":546},"what-is-openvswitch","What is OpenVSwitch",[525,549,550],{},"OpenVSwitch is a SDN application (Software defined networking) that allows you to create networks and switches on software level.",[544,552,554],{"id":553},"requirements","Requirements",[556,557,558,562,565],"ul",{},[559,560,561],"li",{},"At least two servers running Fedora 23 or higher (it may even work with Fedora 21 and higher, but it is not tested!).",[559,563,564],{},"Root access to the servers.",[559,566,567,568,571,572,571,575,578],{},"Network connectivity between the servers (the following protocols need to be allowed: ",[535,569,570],{},"tcp",", ",[535,573,574],{},"udp",[535,576,577],{},"gre",")",[544,580,582],{"id":581},"goals","Goals",[525,584,585],{},"The goal of the tutorial is to create an \"overlay\" network between two and more servers using OpenVSwitch.",[587,588],"hr",{},[544,590,592],{"id":591},"step-1-installing-openvswitch","Step 1 - Installing OpenVSwitch",[522,594,595,599],{},[525,596,597],{},[528,598,530],{},[525,600,601],{},"Do this step on all servers.",[525,603,604,605,607],{},"To install OpenVSwitch on Fedora 24 we use the package manager ",[535,606,537],{},".\nThe command to install the OpenVSwitch package is:",[609,610,615],"pre",{"className":611,"code":612,"language":613,"meta":614,"style":614},"language-bash shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","dnf install openvswitch\n","bash","",[535,616,617],{"__ignoreMap":614},[618,619,622,625,629],"span",{"class":620,"line":621},"line",1,[618,623,537],{"class":624},"sBMFI",[618,626,628],{"class":627},"sfazB"," install",[618,630,631],{"class":627}," openvswitch\n",[525,633,634,635,638,639,646],{},"After the command has been successfully run, you now have OpenVSwitch installed.\nFirst at all we have to start the OpenVSwitch service. To do that we use ",[535,636,637],{},"systemctl"," (more details on how to use systemctl can be seen ",[640,641,645],"a",{"href":642,"rel":643},"https:\u002F\u002Fdocs.openvswitch.org\u002Fen\u002Flatest\u002Fintro\u002Finstall\u002F",[644],"nofollow","here","):",[609,648,650],{"className":611,"code":649,"language":613,"meta":614,"style":614},"systemctl start openvswitch.service\n",[535,651,652],{"__ignoreMap":614},[618,653,654,656,659],{"class":620,"line":621},[618,655,637],{"class":624},[618,657,658],{"class":627}," start",[618,660,661],{"class":627}," openvswitch.service\n",[525,663,664],{},"This starts the OpenVSwitch service.",[522,666,667,672],{},[525,668,669],{},[528,670,671],{},"WARNING",[525,673,674],{},"Don't enable the service yet because if you accidentally \"kill\" your network connection through OpenVSwitch, you can just reboot the server and the configuration will not be loaded.",[544,676,678],{"id":677},"step-2-creating-the-bridge-interface","Step 2 - Creating the bridge interface",[525,680,681],{},"Now that you have OpenVSwitch installed and the service started, you can create the bridge interface.\nThe command for creating an OpenVSwitch bridge device is:",[609,683,685],{"className":611,"code":684,"language":613,"meta":614,"style":614},"ovs-vsctl add-br BRIDGE_NAME\n",[535,686,687],{"__ignoreMap":614},[618,688,689,692,695],{"class":620,"line":621},[618,690,691],{"class":624},"ovs-vsctl",[618,693,694],{"class":627}," add-br",[618,696,697],{"class":627}," BRIDGE_NAME\n",[525,699,700,701,571,704,707,708,710,711,714],{},"When you want to create a bridge named ",[535,702,703],{},"br0",[535,705,706],{},"BRIDGE_NAME"," would be ",[535,709,703],{},". You have now created your bridge interface.\nTo see your bridge interface use the ",[535,712,713],{},"ip"," command (the below output should be similar to yours):",[609,716,718],{"className":611,"code":717,"language":613,"meta":614,"style":614},"$ ip link\n[...]\n4: br0: \u003CBROADCAST,MULTICAST,,LOWER_UP> mtu 1500 qdisc noqueue state DOWN mode DEFAULT group default qlen 1\n    link\u002Fether xx:xx:xx:xx:xx:xx brd ff:ff:ff:ff:ff:ff\n[...]\n",[535,719,720,731,745,803,818],{"__ignoreMap":614},[618,721,722,725,728],{"class":620,"line":621},[618,723,724],{"class":624},"$",[618,726,727],{"class":627}," ip",[618,729,730],{"class":627}," link\n",[618,732,734,738,742],{"class":620,"line":733},2,[618,735,737],{"class":736},"sMK4o","[",[618,739,741],{"class":740},"sTEyZ","...",[618,743,744],{"class":736},"]\n",[618,746,748,751,754,757,760,763,766,769,773,776,779,782,785,788,791,794,797,800],{"class":620,"line":747},3,[618,749,750],{"class":624},"4:",[618,752,753],{"class":627}," br0:",[618,755,756],{"class":736}," \u003C",[618,758,759],{"class":627},"BROADCAST,MULTICAST,,LOWER_U",[618,761,762],{"class":740},"P",[618,764,765],{"class":736},">",[618,767,768],{"class":627}," mtu",[618,770,772],{"class":771},"sbssI"," 1500",[618,774,775],{"class":627}," qdisc",[618,777,778],{"class":627}," noqueue",[618,780,781],{"class":627}," state",[618,783,784],{"class":627}," DOWN",[618,786,787],{"class":627}," mode",[618,789,790],{"class":627}," DEFAULT",[618,792,793],{"class":627}," group",[618,795,796],{"class":627}," default",[618,798,799],{"class":627}," qlen",[618,801,802],{"class":771}," 1\n",[618,804,806,809,812,815],{"class":620,"line":805},4,[618,807,808],{"class":624},"    link\u002Fether",[618,810,811],{"class":627}," xx:xx:xx:xx:xx:xx",[618,813,814],{"class":627}," brd",[618,816,817],{"class":627}," ff:ff:ff:ff:ff:ff\n",[618,819,821,823,825],{"class":620,"line":820},5,[618,822,737],{"class":736},[618,824,741],{"class":740},[618,826,744],{"class":736},[544,828,830],{"id":829},"step-3-preparing-for-the-gre-tunnels","Step 3 - Preparing for the GRE tunnels",[525,832,833],{},"You should now create a list of your servers and beginning from 0 a number for example like this:",[609,835,839],{"className":836,"code":837,"language":838,"meta":614,"style":614},"language-csv shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","server-1 0\nserver-2 1\nserver-3 2\n[...]\nserver-8 7\nserver-9 8\n","csv",[535,840,841,846,851,856,861,866],{"__ignoreMap":614},[618,842,843],{"class":620,"line":621},[618,844,845],{"class":740},"server-1 0\n",[618,847,848],{"class":620,"line":733},[618,849,850],{"class":740},"server-2 1\n",[618,852,853],{"class":620,"line":747},[618,854,855],{"class":740},"server-3 2\n",[618,857,858],{"class":620,"line":805},[618,859,860],{"class":740},"[...]\n",[618,862,863],{"class":620,"line":820},[618,864,865],{"class":740},"server-8 7\n",[618,867,869],{"class":620,"line":868},6,[618,870,871],{"class":740},"server-9 8\n",[525,873,874],{},"The number behind the server name will be the tunnel interface number and needs to be the same on all servers when creating the meshed tunnel network.",[522,876,877],{},[525,878,879,881],{},[528,880,530],{}," Save this list somewhere safe, it is very important when you later want to expand your network.",[525,883,884],{},"A list for three servers with the interface name and IP address written behind the lines:",[609,886,888],{"className":836,"code":887,"language":838,"meta":614,"style":614},"server-1 0 gre0 IP: 1.1.1.1\nserver-2 1 gre1 IP: 2.2.2.2\nserver-3 2 gre2 IP: 3.3.3.3\n",[535,889,890,895,900],{"__ignoreMap":614},[618,891,892],{"class":620,"line":621},[618,893,894],{"class":740},"server-1 0 gre0 IP: 1.1.1.1\n",[618,896,897],{"class":620,"line":733},[618,898,899],{"class":740},"server-2 1 gre1 IP: 2.2.2.2\n",[618,901,902],{"class":620,"line":747},[618,903,904],{"class":740},"server-3 2 gre2 IP: 3.3.3.3\n",[525,906,907,908,910],{},"Your server firewall should not block the GRE tunnel protocol traffic.\nFor iptables the protocol name is ",[535,909,577],{},".\nAn example rule to allow all GRE tunnel protocol traffic:",[609,912,914],{"className":611,"code":913,"language":613,"meta":614,"style":614},"iptables -A INPUT -p gre -j ACCEPT\n",[535,915,916],{"__ignoreMap":614},[618,917,918,921,924,927,930,933,936],{"class":620,"line":621},[618,919,920],{"class":624},"iptables",[618,922,923],{"class":627}," -A",[618,925,926],{"class":627}," INPUT",[618,928,929],{"class":627}," -p",[618,931,932],{"class":627}," gre",[618,934,935],{"class":627}," -j",[618,937,938],{"class":627}," ACCEPT\n",[544,940,942],{"id":941},"step-4-opening-the-gre-tunnels","Step 4 - Opening the GRE tunnels",[525,944,945],{},"Before creating the first GRE tunnels you should know that it will not make any sense if you have more than 3-4 servers to link all of them together. You should create a redundant mesh between your servers and not link all to all.",[522,947,948,952],{},[525,949,950],{},[528,951,530],{},[525,953,954,955,957],{},"Where ",[535,956,703],{}," in the commands is your bridge device. Please change it according to your bridge name.",[525,959,960,961,964],{},"Starting on your the first server (IP: ",[535,962,963],{},"1.1.1.1","), we create the tunnel to the second and third server:",[609,966,968],{"className":611,"code":967,"language":613,"meta":614,"style":614},"ovs-vsctl add-port br0 gre1 -- set interface gre1 type=gre options:remote_ip=2.2.2.2\novs-vsctl add-port br0 gre1 -- set interface gre2 type=gre options:remote_ip=3.3.3.3\n",[535,969,970,1003],{"__ignoreMap":614},[618,971,972,974,977,980,983,986,989,992,994,997,1000],{"class":620,"line":621},[618,973,691],{"class":624},[618,975,976],{"class":627}," add-port",[618,978,979],{"class":627}," br0",[618,981,982],{"class":627}," gre1",[618,984,985],{"class":627}," --",[618,987,988],{"class":627}," set",[618,990,991],{"class":627}," interface",[618,993,982],{"class":627},[618,995,996],{"class":627}," type=gre",[618,998,999],{"class":627}," options:remote_ip=",[618,1001,1002],{"class":771},"2.2.2.2\n",[618,1004,1005,1007,1009,1011,1013,1015,1017,1019,1022,1024,1026],{"class":620,"line":733},[618,1006,691],{"class":624},[618,1008,976],{"class":627},[618,1010,979],{"class":627},[618,1012,982],{"class":627},[618,1014,985],{"class":627},[618,1016,988],{"class":627},[618,1018,991],{"class":627},[618,1020,1021],{"class":627}," gre2",[618,1023,996],{"class":627},[618,1025,999],{"class":627},[618,1027,1028],{"class":771},"3.3.3.3\n",[525,1030,1031,1032,1035],{},"On the second server (",[535,1033,1034],{},"2.2.2.2",") we now create the tunnel to the first and third server with the commands:",[609,1037,1039],{"className":611,"code":1038,"language":613,"meta":614,"style":614},"ovs-vsctl add-port br0 gre0 -- set interface gre0 type=gre options:remote_ip=1.1.1.1\novs-vsctl add-port br0 gre0 -- set interface gre2 type=gre options:remote_ip=3.3.3.3\n",[535,1040,1041,1067],{"__ignoreMap":614},[618,1042,1043,1045,1047,1049,1052,1054,1056,1058,1060,1062,1064],{"class":620,"line":621},[618,1044,691],{"class":624},[618,1046,976],{"class":627},[618,1048,979],{"class":627},[618,1050,1051],{"class":627}," gre0",[618,1053,985],{"class":627},[618,1055,988],{"class":627},[618,1057,991],{"class":627},[618,1059,1051],{"class":627},[618,1061,996],{"class":627},[618,1063,999],{"class":627},[618,1065,1066],{"class":771},"1.1.1.1\n",[618,1068,1069,1071,1073,1075,1077,1079,1081,1083,1085,1087,1089],{"class":620,"line":733},[618,1070,691],{"class":624},[618,1072,976],{"class":627},[618,1074,979],{"class":627},[618,1076,1051],{"class":627},[618,1078,985],{"class":627},[618,1080,988],{"class":627},[618,1082,991],{"class":627},[618,1084,1021],{"class":627},[618,1086,996],{"class":627},[618,1088,999],{"class":627},[618,1090,1028],{"class":771},[525,1092,1093,1094,1097],{},"On the third server (",[535,1095,1096],{},"3.3.3.3",") we create the tunnel back to the first and second server so the three server mesh is complete:",[609,1099,1101],{"className":611,"code":1100,"language":613,"meta":614,"style":614},"ovs-vsctl add-port br0 gre0 -- set interface gre0 type=gre options:remote_ip=1.1.1.1\novs-vsctl add-port br0 gre0 -- set interface gre1 type=gre options:remote_ip=2.2.2.2\n",[535,1102,1103,1127],{"__ignoreMap":614},[618,1104,1105,1107,1109,1111,1113,1115,1117,1119,1121,1123,1125],{"class":620,"line":621},[618,1106,691],{"class":624},[618,1108,976],{"class":627},[618,1110,979],{"class":627},[618,1112,1051],{"class":627},[618,1114,985],{"class":627},[618,1116,988],{"class":627},[618,1118,991],{"class":627},[618,1120,1051],{"class":627},[618,1122,996],{"class":627},[618,1124,999],{"class":627},[618,1126,1066],{"class":771},[618,1128,1129,1131,1133,1135,1137,1139,1141,1143,1145,1147,1149],{"class":620,"line":733},[618,1130,691],{"class":624},[618,1132,976],{"class":627},[618,1134,979],{"class":627},[618,1136,1051],{"class":627},[618,1138,985],{"class":627},[618,1140,988],{"class":627},[618,1142,991],{"class":627},[618,1144,982],{"class":627},[618,1146,996],{"class":627},[618,1148,999],{"class":627},[618,1150,1002],{"class":771},[544,1152,1154],{"id":1153},"step-5-adding-ip-addresses-to-the-bridges","Step 5 - Adding IP addresses to the bridges",[525,1156,1157,1158,1161],{},"You can now add an extra field to the exisiting server list which contains the network range.\nIn the tutorial case the network will be ",[535,1159,1160],{},"10.244.0.0\u002F16"," network, so the list looks like this:",[609,1163,1165],{"className":836,"code":1164,"language":838,"meta":614,"style":614},"server-1 0 gre0 IP: 1.1.1.1 Network: 10.244.1.0\nserver-2 1 gre1 IP: 2.2.2.2 Network: 10.244.2.0\nserver-3 2 gre2 IP: 3.3.3.3 Network: 10.244.3.0\n",[535,1166,1167,1172,1177],{"__ignoreMap":614},[618,1168,1169],{"class":620,"line":621},[618,1170,1171],{"class":740},"server-1 0 gre0 IP: 1.1.1.1 Network: 10.244.1.0\n",[618,1173,1174],{"class":620,"line":733},[618,1175,1176],{"class":740},"server-2 1 gre1 IP: 2.2.2.2 Network: 10.244.2.0\n",[618,1178,1179],{"class":620,"line":747},[618,1180,1181],{"class":740},"server-3 2 gre2 IP: 3.3.3.3 Network: 10.244.3.0\n",[522,1183,1184,1188],{},[525,1185,1186],{},[528,1187,530],{},[525,1189,1190],{},"It is important to know what servers uses which IP address to avoid address conflicts.\nIf you changed the CIDR of the network range from the tutorial, you also have to change the broadcast address in the below commands.",[525,1192,1193,1194,1196],{},"Now that you have decided what server has what network slice, we can set the interface up and add the IP addresses to the bridge on each server.\nOn the first server (",[535,1195,963],{},") the command would look like this:",[609,1198,1200],{"className":611,"code":1199,"language":613,"meta":614,"style":614},"ip link set br0 up\nip addr add 10.244.1.0\u002F16 broadcast 10.244.255.255 dev br0\n",[535,1201,1202,1216],{"__ignoreMap":614},[618,1203,1204,1206,1209,1211,1213],{"class":620,"line":621},[618,1205,713],{"class":624},[618,1207,1208],{"class":627}," link",[618,1210,988],{"class":627},[618,1212,979],{"class":627},[618,1214,1215],{"class":627}," up\n",[618,1217,1218,1220,1223,1226,1229,1232,1235,1238],{"class":620,"line":733},[618,1219,713],{"class":624},[618,1221,1222],{"class":627}," addr",[618,1224,1225],{"class":627}," add",[618,1227,1228],{"class":627}," 10.244.1.0\u002F16",[618,1230,1231],{"class":627}," broadcast",[618,1233,1234],{"class":771}," 10.244.255.255",[618,1236,1237],{"class":627}," dev",[618,1239,1240],{"class":627}," br0\n",[525,1242,1031,1243,1245],{},[535,1244,1034],{},") the command is slightly different due to the other address:",[609,1247,1249],{"className":611,"code":1248,"language":613,"meta":614,"style":614},"ip addr add 10.244.2.0\u002F16 broadcast 10.244.255.255 dev br0\n",[535,1250,1251],{"__ignoreMap":614},[618,1252,1253,1255,1257,1259,1262,1264,1266,1268],{"class":620,"line":621},[618,1254,713],{"class":624},[618,1256,1222],{"class":627},[618,1258,1225],{"class":627},[618,1260,1261],{"class":627}," 10.244.2.0\u002F16",[618,1263,1231],{"class":627},[618,1265,1234],{"class":771},[618,1267,1237],{"class":627},[618,1269,1240],{"class":627},[525,1271,1272],{},"And so on with different IP addresses per server.",[544,1274,1276],{"id":1275},"step-6-checking-the-virtual-network-connectivity","Step 6 - Checking the virtual network connectivity",[525,1278,1279,1280,1283,1284,1286],{},"Now that every server has it's own IP address in the virtual network, we can check the connectivity.\nWe are going to use the ",[535,1281,1282],{},"ping"," command for testing the connectivity between the servers.\nFrom the first server (",[535,1285,963],{},") run:",[609,1288,1290],{"className":611,"code":1289,"language":613,"meta":614,"style":614},"ping 10.244.2.0\n",[535,1291,1292],{"__ignoreMap":614},[618,1293,1294,1296],{"class":620,"line":621},[618,1295,1282],{"class":624},[618,1297,1298],{"class":771}," 10.244.2.0\n",[525,1300,1301,1302,1305,1306,1309,1310,1313],{},"If you should not receive a ping response in the next 10 seconds, it may be caused by a setting called ",[535,1303,1304],{},"proxy_arp"," in the ",[535,1307,1308],{},"\u002Fsys"," ",[535,1311,1312],{},"net.ipv4"," \"category\".",[522,1315,1316,1320],{},[525,1317,1318],{},[528,1319,530],{},[525,1321,954,1322,1324],{},[535,1323,703],{}," in the command(s) is your bridge device. Please change it according to your bridge name.",[609,1326,1328],{"className":611,"code":1327,"language":613,"meta":614,"style":614},"sysctl -w net.ipv4.conf.br0.proxy_arp=1\n",[535,1329,1330],{"__ignoreMap":614},[618,1331,1332,1334,1337,1340],{"class":620,"line":621},[618,1333,276],{"class":624},[618,1335,1336],{"class":627}," -w",[618,1338,1339],{"class":627}," net.ipv4.conf.br0.proxy_arp=",[618,1341,1342],{"class":771},"1\n",[525,1344,1345],{},"To persist this change you can run:",[609,1347,1349],{"className":611,"code":1348,"language":613,"meta":614,"style":614},"echo \"net.ipv4.conf.br0.proxy_arp=1\" >> \u002Fetc\u002Fsysctl.conf\n",[535,1350,1351],{"__ignoreMap":614},[618,1352,1353,1357,1360,1363,1366,1369],{"class":620,"line":621},[618,1354,1356],{"class":1355},"s2Zo4","echo",[618,1358,1359],{"class":736}," \"",[618,1361,1362],{"class":627},"net.ipv4.conf.br0.proxy_arp=1",[618,1364,1365],{"class":736},"\"",[618,1367,1368],{"class":736}," >>",[618,1370,1371],{"class":627}," \u002Fetc\u002Fsysctl.conf\n",[522,1373,1374,1378],{},[525,1375,1376],{},[528,1377,530],{},[525,1379,1380,1381,1384],{},"The ",[535,1382,1383],{},"\u002Fetc\u002Fsysctl.conf"," file is loaded on every boot.",[525,1386,1387],{},"Now after that change, retry to ping and it now should work.",[544,1389,1391],{"id":1390},"summary","Summary",[525,1393,1394],{},"As long as you build a good mesh between the servers the virtual network between the servers will be redundant.\nBut don't over do the mesh building between the servers. As mentioned earlier too many tunnels is too much.",[525,1396,1397],{},"Have Fun!",[1399,1400,1401],"style",