con":500,"path":501,"stem":502,"children":503,"page":22},"Tiptap","i-mdi-file-edit-outline","\u002Fdocs\u002Fweb\u002Ftiptap","1.docs\u002Fweb\u002Ftiptap",[504],{"title":505,"path":506,"stem":507},"Snippets","\u002Fdocs\u002Fweb\u002Ftiptap\u002Fsnippets","1.docs\u002Fweb\u002Ftiptap\u002Fsnippets",{"id":509,"title":510,"authors":511,"badge":517,"body":518,"date":915,"description":916,"extension":917,"image":918,"meta":920,"navigation":923,"path":924,"seo":925,"stem":926,"__hash__":927},"posts\u002F3.blog\u002F2016\u002Fopenvswitch-persistent-ip-configuration-under-rhel-based-distros.md","OpenVSwitch: Persistent IP configuration under Rhel based distros",[512],{"name":513,"to":514,"avatar":515},"Alexander Trost","https:\u002F\u002Fgithub.com\u002Fgalexrt",{"src":516},"\u002Fimages\u002Fprofile-picture.jpg",null,{"type":519,"value":520,"toc":909},"minimark",[521,545,550,553,578,585,600,614,617,621,630,637,781,788,862,865,868,890,894,905],[522,523,524,531],"blockquote",{},[525,526,527],"p",{},[528,529,530],"strong",{},"NOTE",[525,532,533,534,539,540,544],{},"This post is a follow up on my post ",[535,536,538],"a",{"href":537},"\u002Fblog\u002F2016\u002Fopenvswitch-multi-host-overlay-network\u002F","OpenVSwitch: Multi-Host Overlay Network",".\nThe interface in this example is named ",[541,542,543],"code",{},"br0",". Change according to your interface.",[546,547,549],"h2",{"id":548},"preparing-for-using-the-interface-configurations","Preparing for using the interface configurations",[525,551,552],{},"To persist the configurations you can either use the NetworkManager or use good old network-scripts.\nHere I'm going to show how it's done using the good old network-scripts.\nFirst at all we have to disable the NetworkManager service with this command:",[554,555,560],"pre",{"className":556,"code":557,"language":558,"meta":559,"style":559},"language-bash shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","systemctl disable NetworkManager.service\n","bash","",[541,561,562],{"__ignoreMap":559},[563,564,567,571,575],"span",{"class":565,"line":566},"line",1,[563,568,570],{"class":569},"sBMFI","systemctl",[563,572,574],{"class":573},"sfazB"," disable",[563,576,577],{"class":573}," NetworkManager.service\n",[525,579,580,581,584],{},"And enable the old fashioned ",[541,582,583],{},"network.service"," with:",[554,586,588],{"className":556,"code":587,"language":558,"meta":559,"style":559},"systemctl enable network.service\n",[541,589,590],{"__ignoreMap":559},[563,591,592,594,597],{"class":565,"line":566},[563,593,570],{"class":569},[563,595,596],{"class":573}," enable",[563,598,599],{"class":573}," network.service\n",[522,601,602,607],{},[525,603,604],{},[528,605,606],{},"WARNING",[525,608,609,610,613],{},"You need to have properly configured network-scripts for your other \"normal\" interfaces too (like ",[541,611,612],{},"enp3s0",") or else after a reboot the network connectivity to your server will not work correctly!!",[525,615,616],{},"We can now go on to creating the configuration for the OpenVSwitch bridges and ports.",[546,618,620],{"id":619},"creating-configuration-for-an-interface-named-obr0","Creating configuration for an interface named obr0",[522,622,623,627],{},[525,624,625],{},[528,626,530],{},[525,628,629],{},"You should only need to persist IP configurations for bridge devices and not ports.",[525,631,632,633,636],{},"Create a file called ",[541,634,635],{},"\u002Fetc\u002Fsysconfig\u002Fnetwork-scripts\u002Fifcfg-obr0",":",[554,638,642],{"className":639,"code":640,"language":641,"meta":559,"style":559},"language-ini shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","NAME=\"obr0\"\nDEVICE=\"obr0\"\nNM_CONTROLLED=\"yes\"\nONBOOT=\"yes\"\nIPV6INIT=no\nTYPE=\"OVSBridge\"\nDEVICETYPE=\"ovs\"\nMTU=1400\nIPADDR=10.244.1.0\nPREFIX=16\n","ini",[541,643,644,663,677,692,706,718,733,748,759,770],{"__ignoreMap":559},[563,645,646,650,654,657,660],{"class":565,"line":566},[563,647,649],{"class":648},"swJcz","NAME",[563,651,653],{"class":652},"sMK4o","=",[563,655,656],{"class":652},"\"",[563,658,659],{"class":573},"obr0",[563,661,662],{"class":652},"\"\n",[563,664,666,669,671,673,675],{"class":565,"line":665},2,[563,667,668],{"class":648},"DEVICE",[563,670,653],{"class":652},[563,672,656],{"class":652},[563,674,659],{"class":573},[563,676,662],{"class":652},[563,678,680,683,685,687,690],{"class":565,"line":679},3,[563,681,682],{"class":648},"NM_CONTROLLED",[563,684,653],{"class":652},[563,686,656],{"class":652},[563,688,689],{"class":573},"yes",[563,691,662],{"class":652},[563,693,695,698,700,702,704],{"class":565,"line":694},4,[563,696,697],{"class":648},"ONBOOT",[563,699,653],{"class":652},[563,701,656],{"class":652},[563,703,689],{"class":573},[563,705,662],{"class":652},[563,707,709,712,714],{"class":565,"line":708},5,[563,710,711],{"class":648},"IPV6INIT",[563,713,653],{"class":652},[563,715,717],{"class":716},"sTEyZ","no\n",[563,719,721,724,726,728,731],{"class":565,"line":720},6,[563,722,723],{"class":648},"TYPE",[563,725,653],{"class":652},[563,727,656],{"class":652},[563,729,730],{"class":573},"OVSBridge",[563,732,662],{"class":652},[563,734,736,739,741,743,746],{"class":565,"line":735},7,[563,737,738],{"class":648},"DEVICETYPE",[563,740,653],{"class":652},[563,742,656],{"class":652},[563,744,745],{"class":573},"ovs",[563,747,662],{"class":652},[563,749,751,754,756],{"class":565,"line":750},8,[563,752,753],{"class":648},"MTU",[563,755,653],{"class":652},[563,757,758],{"class":716},"1400\n",[563,760,762,765,767],{"class":565,"line":761},9,[563,763,764],{"class":648},"IPADDR",[563,766,653],{"class":652},[563,768,769],{"class":716},"10.244.1.0\n",[563,771,773,776,778],{"class":565,"line":772},10,[563,774,775],{"class":648},"PREFIX",[563,777,653],{"class":652},[563,779,780],{"class":716},"16\n",[522,782,783],{},[525,784,785],{},[528,786,787],{},"WDWD",[789,790,791,798,803,808,820,825,836,845,851,857],"ul",{},[792,793,794,797],"li",{},[541,795,796],{},"NAME=\"YOUR_INTERFACE_NAME\""," - The name of the interface.",[792,799,800,797],{},[541,801,802],{},"DEVICE=\"YOUR_DEVICE_NAME\"",[792,804,805,797],{},[541,806,807],{},"NM_CONTROLLED=\"yes\"",[792,809,810,813,814,816,817,819],{},[541,811,812],{},"ONBOOT=\"INTERFACE_NAME\""," - If ",[541,815,689],{},", the interface is created when the server boots. Should be ",[541,818,689],{}," in most cases.",[792,821,822,797],{},[541,823,824],{},"IPV6INIT=\"INTERFACE_NAME\"",[792,826,827,830,831,835],{},[541,828,829],{},"TYPE=\"OVSBridge\""," - The type of the  interface (see ",[535,832,834],{"href":833},"#OpenVSwitch-related-configuration","OpenVSwitch related configuration"," for more info)",[792,837,838,841,842,844],{},[541,839,840],{},"DEVICETYPE=\"ovs\""," - The device type of the interface (see ",[535,843,834],{"href":833}," for more info).",[792,846,847,850],{},[541,848,849],{},"MTU=YOUR_MTU"," - The MTU of the interface (Only add this option if you know what you are doing).",[792,852,853,856],{},[541,854,855],{},"IPADDR=YOUR_INTERFACE_IP_ADDRESS"," - The name of the created interface.",[792,858,859,856],{},[541,860,861],{},"PREFIX=YOUR_NETWORK_PREFIX",[546,863,834],{"id":864},"openvswitch-related-configuration",[525,866,867],{},"The following options\u002Farguments are important when configuring OpenVSwitch created interfaces:",[789,869,870,882],{},[792,871,872,874,875,877,878,881],{},[541,873,738],{}," - For a bridge interface use ",[541,876,730],{}," and for a port interface use ",[541,879,880],{},"OVSPort",".",[792,883,884,886,887,889],{},[541,885,723],{}," - Always ",[541,888,745],{}," for a OpenVSwitch interface.",[546,891,893],{"id":892},"summary","Summary",[525,895,896,897,900,901,904],{},"That's all you need to do, disable the ",[541,898,899],{},"NetworkManager.service"," and activate the good old ",[541,902,903],{},"network"," service.",[906,907,908],"style",{},"html pre.shiki code .sBMFI, html code.shiki .sBMFI{--shiki-light:#E2931D;--shiki-d