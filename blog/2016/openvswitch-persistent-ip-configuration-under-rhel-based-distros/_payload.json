d":864,"depth":665,"text":834},{"id":892,"depth":665,"text":893},"2016-08-11T18:22:22+02:00","Persisting the interface IP configuration for OpenVSwitch interfaces\u002Fdevices under Rhel based distros.","md",{"src":919},"\u002Fblog\u002F2016\u002Fopenvswitch-persistent-ip-configuration-under-rhel-based-distros\u002Fpost_title_image.png",{"tags":921},[193,922],"OpenVSwitch",true,"\u002Fblog\u002F2016\u002Fopenvswitch-persistent-ip-configuration-under-rhel-based-distros",{"title":510,"description":916},"3.blog\u002F2016\u002Fopenvswitch-persistent-ip-configuration-under-rhel-based-distros","lJHE2gDv89P5DeGnyj_eZ2vleXkO4d4tz50E08EzXrM",[929,933],{"title":538,"path":930,"stem":931,"description":932,"children":-1},"\u002Fblog\u002F2016\u002Fopenvswitch-multi-host-overlay-network","3.blog\u002F2016\u002Fopenvswitch-multi-host-overlay-network","Creating a mutli-host overlay network between two and more servers.",{"title":934,"path":935,"stem":936,"description":937,"children":-1},"PSA: Keep your computer clean!","\u002Fblog\u002F2016\u002Fpsa-keep-your-computer-clean","3.blog\u002F2016\u002Fpsa-keep-your-computer-clean","Keep your computer(s) clean for them to work even now when a hot summer is around the corner.",1778939441364]