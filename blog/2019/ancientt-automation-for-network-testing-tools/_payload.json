en":503,"page":22},"Tiptap","i-mdi-file-edit-outline","\u002Fdocs\u002Fweb\u002Ftiptap","1.docs\u002Fweb\u002Ftiptap",[504],{"title":505,"path":506,"stem":507},"Snippets","\u002Fdocs\u002Fweb\u002Ftiptap\u002Fsnippets","1.docs\u002Fweb\u002Ftiptap\u002Fsnippets",{"id":509,"title":510,"authors":511,"badge":517,"body":518,"date":969,"description":970,"extension":971,"image":972,"meta":974,"navigation":981,"path":982,"seo":983,"stem":984,"__hash__":985},"posts\u002F3.blog\u002F2019\u002Fancientt-automation-for-network-testing-tools.md","Ancientt - Automation for Network Testing Tools",[512],{"name":513,"to":514,"avatar":515},"Alexander Trost","https:\u002F\u002Fgithub.com\u002Fgalexrt",{"src":516},"\u002Fimages\u002Fprofile-picture.jpg",null,{"type":519,"value":520,"toc":961},"minimark",[521,543,546,551,559,565,818,825,835,848,853,856,862,873,877,885,897,901,909,923,932,936,942,948,951,954,957],[522,523,524,525,532,533,538,539,542],"p",{},"This is a ",[526,527,531],"a",{"href":528,"rel":529},"http:\u002F\u002Fthe-report.cloud\u002Fancientt-automation-for-network-testing-tools",[530],"nofollow","cross post"," from ",[526,534,537],{"href":535,"rel":536},"http:\u002F\u002Fthe-report.cloud\u002F",[530],"The Cloud Report",".\nBe sure to checkout the ",[526,540,537],{"href":535,"rel":541},[530]," website.",[544,545],"hr",{},[547,548,550],"h2",{"id":549},"what-is-ancientt","What is Ancientt",[522,552,553,554,558],{},"Ancientt is a tool to automate network testing tools, like ",[555,556,557],"code",{},"iperf3",", in dynamic environments such as Kubernetes, Ansible and more to come dynamic environments.",[522,560,561,562,564],{},"Meaning that, if you want to test the network throughput with ",[555,563,557],{}," of your Kubernetes cluster, you can easily do that with Ancientt.\nA simple \"test definitions\" file is used to tell Ancientt what exactly to do:",[566,567,572],"pre",{"className":568,"code":569,"language":570,"meta":571,"style":571},"language-yaml shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","version: '0'\nrunner:\n  name: kubernetes\n  kubernetes: {}\ntests:\n- name: iperf3-one-random-to-all-nodes\n  type: iperf3\n  outputs:\n  - name: csv\n    csv:\n      filePath: .\n      namePattern: 'ancientt-results-{{ .Data.Tester }}.csv'\n  hosts:\n    servers:\n    - name: one-random\n      random: true\n      count: 1\n    clients:\n    - name: all-hosts\n      all: true\n  iperf3:\n    duration: 30\n","yaml","",[555,573,574,597,606,617,628,636,650,661,669,682,690,702,717,725,733,746,758,769,777,789,799,807],{"__ignoreMap":571},[575,576,579,583,587,590,594],"span",{"class":577,"line":578},"line",1,[575,580,582],{"class":581},"swJcz","version",[575,584,586],{"class":585},"sMK4o",":",[575,588,589],{"class":585}," '",[575,591,593],{"class":592},"sfazB","0",[575,595,596],{"class":585},"'\n",[575,598,600,603],{"class":577,"line":599},2,[575,601,602],{"class":581},"runner",[575,604,605],{"class":585},":\n",[575,607,609,612,614],{"class":577,"line":608},3,[575,610,611],{"class":581},"  name",[575,613,586],{"class":585},[575,615,616],{"class":592}," kubernetes\n",[575,618,620,623,625],{"class":577,"line":619},4,[575,621,622],{"class":581},"  kubernetes",[575,624,586],{"class":585},[575,626,627],{"class":585}," {}\n",[575,629,631,634],{"class":577,"line":630},5,[575,632,633],{"class":581},"tests",[575,635,605],{"class":585},[575,637,639,642,645,647],{"class":577,"line":638},6,[575,640,641],{"class":585},"-",[575,643,644],{"class":581}," name",[575,646,586],{"class":585},[575,648,649],{"class":592}," iperf3-one-random-to-all-nodes\n",[575,651,653,656,658],{"class":577,"line":652},7,[575,654,655],{"class":581},"  type",[575,657,586],{"class":585},[575,659,660],{"class":592}," iperf3\n",[575,662,664,667],{"class":577,"line":663},8,[575,665,666],{"class":581},"  outputs",[575,668,605],{"class":585},[575,670,672,675,677,679],{"class":577,"line":671},9,[575,673,674],{"class":585},"  -",[575,676,644],{"class":581},[575,678,586],{"class":585},[575,680,681],{"class":592}," csv\n",[575,683,685,688],{"class":577,"line":684},10,[575,686,687],{"class":581},"    csv",[575,689,605],{"class":585},[575,691,693,696,698],{"class":577,"line":692},11,[575,694,695],{"class":581},"      filePath",[575,697,586],{"class":585},[575,699,701],{"class":700},"sbssI"," .\n",[575,703,705,708,710,712,715],{"class":577,"line":704},12,[575,706,707],{"class":581},"      namePattern",[575,709,586],{"class":585},[575,711,589],{"class":585},[575,713,714],{"class":592},"ancientt-results-{{ .Data.Tester }}.csv",[575,716,596],{"class":585},[575,718,720,723],{"class":577,"line":719},13,[575,721,722],{"class":581},"  hosts",[575,724,605],{"class":585},[575,726,728,731],{"class":577,"line":727},14,[575,729,730],{"class":581},"    servers",[575,732,605],{"class":585},[575,734,736,739,741,743],{"class":577,"line":735},15,[575,737,738],{"class":585},"    -",[575,740,644],{"class":581},[575,742,586],{"class":585},[575,744,745],{"class":592}," one-random\n",[575,747,749,752,754],{"class":577,"line":748},16,[575,750,751],{"class":581},"      random",[575,753,586],{"class":585},[575,755,757],{"class":756},"sfNiH"," true\n",[575,759,761,764,766],{"class":577,"line":760},17,[575,762,763],{"class":581},"      count",[575,765,586],{"class":585},[575,767,768],{"class":700}," 1\n",[575,770,772,775],{"class":577,"line":771},18,[575,773,774],{"class":581},"    clients",[575,776,605],{"class":585},[575,778,780,782,784,786],{"class":577,"line":779},19,[575,781,738],{"class":585},[575,783,644],{"class":581},[575,785,586],{"class":585},[575,787,788],{"class":592}," all-hosts\n",[575,790,792,795,797],{"class":577,"line":791},20,[575,793,794],{"class":581},"      all",[575,796,586],{"class":585},[575,798,757],{"class":756},[575,800,802,805],{"class":577,"line":801},21,[575,803,804],{"class":581},"  iperf3",[575,806,605],{"class":585},[575,808,810,813,815],{"class":577,"line":809},22,[575,811,812],{"class":581},"    duration",[575,814,586],{"class":585},[575,816,817],{"class":700}," 30\n",[522,819,820,821,824],{},"The above \"test definitions\" file tells Ancinett, to use the Kubernetes \"runner\", to run a test from one randomly chosen Node to all the other Nodes (+ itself) in the Kubernetes cluster.\nTest results are stored as CSV in files named after the given ",[555,822,823],{},"namePattern"," to make it easy to split results by \"server\", \"client\" and other available variables.",[826,827,828],"blockquote",{},[522,829,830,834],{},[831,832,833],"strong",{},"NOTE"," It doesn't have to be a Kubernetes cluster, an OpenShift cluster works as well.",[522,836,837,838,847],{},"Besides being able to run on Kubernetes and OpenShift, you can also provide an Ansible inventory file which also can be used to run tests on it.\nThe targeted hosts need to have the network testing tools installed as of right now. An example Ansible playbook can be found here: ",[526,839,842,843,846],{"href":840,"rel":841},"https:\u002F\u002Fgithub.com\u002Fcloudical-io\u002Fancientt\u002Ftree\u002Fmaster\u002Fexamples\u002Frunners\u002Fansible",[530],"GitHub cloudical-io\u002Fancientt - ",[555,844,845],{},"examples\u002Frunners\u002Fansible"," directory",".",[849,850,852],"h3",{"id":851},"why-did-we-create-ancientt","Why did we create Ancientt",[522,854,855],{},"More and more people are moving to platforms like Kubernetes, OpenStack, OpenShift and others. The biggest problem we see in such installments is most of the time the network. Either because of performance, latency or general connectivity issues.",[522,857,858,859,861],{},"Ancientt right now allows us to easily run ",[555,860,557],{}," tests across whole Kubernetes and OpenShift clusters, and normal machines (through Ansible). Doing such tests manually takes a lot of time away from  other potentially critical points that should be investigated.\nWith Ancientt you can easily run such tests faster. This should save you time and the results hopefully get you faster to a resolution of the problem and\u002F or improving your network performance.",[522,863,864,865,868,869,872],{},"We'll hopefully soon be able to add more network testing tools to the list, to make it even easier to run tests. E.g., ",[555,866,867],{},"smokeping",", ",[555,870,871],{},"siege"," and others, should be able to help with latency and performance tests.",[849,874,876],{"id":875},"future-of-ancientt","Future of Ancientt",[522,878,879,880,847],{},"For the near future, we'll focus on making it possible to get the results into Prometheus. This would allow for constant network testing, monitoring and alerting on issues.\nIf you have a good idea on how this can be achieved, feel free to comment on ",[526,881,884],{"href":882,"rel":883},"https:\u002F\u002Fgithub.com\u002Fcloudical-io\u002Fancientt\u002Fissues\u002F38",[530],"GitHub cloudical-io\u002Fancientt - Issue 'outputs: Prometheus' #38",[522,886,887,888,891,892,847],{},"As written in the ",[526,889,852],{"href":890},"#why-did-we-create-ancientt"," section, we'll look into adding more network testing tools.\nFor a list of potential new network testing tools to be worked on for Ancinett, checkout ",[526,893,896],{"href":894,"rel":895},"https:\u002F\u002Fgithub.com\u002Fcloudical-io\u002Fancientt\u002Fissues?q=is%3Aissue+is%3Aopen+label%3Atesters",[530],"GitHub cloudical-io\u002Fancientt Issues with Label `testers",[849,898,900],{"id":899},"wanna-try-out-ancientt","Wanna try out Ancientt?",[522,902,903,904,847],{},"Checkout the Ancientt project on GitHub: ",[526,905,908],{"href":906,"rel":907},"https:\u002F\u002Fgithub.com\u002Fcloudical-io\u002Fancientt\u002F",[530],"GitHub cloudical-io\u002Fancientt",[522,910,911,912,917,918,847],{},"To get you started on the test definition options available, there is a ",[526,913,916],{"href":914,"rel":915},"https:\u002F\u002Fgithub.com\u002Fcloudical-io\u002Fancientt\u002Fblob\u002Fmaster\u002Fdocs\u002Fconfig-examples.md",[530],"config examples doc page",".\nIf you want to dive into all available test defintion options, see ",[526,919,922],{"href":920,"rel":921},"https:\u002F\u002Fgithub.com\u002Fcloudical-io\u002Fancientt\u002Fblob\u002Fmaster\u002Fdocs\u002Fconfig-structure.md",[530],"onfig structure doc page",[522,924,925,926,847],{},"All available documentation can be found in the ",[526,927,842,930,846],{"href":928,"rel":929},"https:\u002F\u002Fgithub.com\u002Fcloudical-io\u002Fancientt\u002Ftree\u002Fmaster\u002Fdocs",[530],[555,931,7],{},[547,933,935],{"id":934},"summary","Summary",[522,937,938,939,941],{},"Ancientt can help you run ",[555,940,557],{}," tests, soon other network test tools as well, in a Kubernetes and OpenShift clusters, and using Ansible in an organized and quick way. Most importantly also collect the test results in an orderly fashion in output formats, like CSV, Excel, MySQL and SQLite.",[522,943,944,945,847],{},"Be sure to check out the project on GitHub: ",[526,946,908],{"href":906,"rel":947},[530],[522,949,950],{},"We are happy about any contributions, be it documentation or code changes.",[522,952,953],{},"If you like the project, be sure to leave a Star to help the project reach more people.",[522,955,956],{},"Have Fun!",[958,959,960],"style",{},"html pre.shiki code .swJcz, html code.shiki .swJcz{--shiki-light:#E53935;--shiki-default:#F07178;--shiki-dark:#F07178}html pre.shiki code .sMK4o, html code.shiki .sMK4o{--shiki-light:#39ADB5;--shiki-default:#89DDFF;--shiki-dark:#89DDFF}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859;--shiki-default:#C3E88D;--shiki-dark:#C3E88D}html pre.shiki code .sbssI, html code.shiki .sbssI{--shiki-light:#F76D47;--shiki-default:#F78C6C;--shiki-dark:#F78C6C}html pre.shiki code .sfNiH, html code.shiki .sfNiH{--shiki-light:#FF5370;--shiki-default:#FF9CAC;--shiki-dark:#FF9CAC}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}",{"title":571,"searchDepth":599,"depth":599,"links":962},[963,968],{"id":549,"depth":599,"text":550,"children":964},[965,966,967],{"id":851,"depth":608,"text":852},{"id":875,"depth":608,"text":876},{"id":899,"depth":608,"text":900},{"id":934,"depth":599,"text":935},"2019-10-12T13:10:52+02:00","Let's see what Ancientt is and how Ancientt can help by automating certain network testing tools.","md",{"src":973},"\u002Fblog\u002F2019\u002Fancientt-automation-for-network-testing-tools\u002Fancientt.jpg",{"tags":975},[976,977,176,978,979,980],"Articles","Network","Open Source","Project","Ancientt",true,"\u002Fblog\u002F2019\u002Fancientt-automation-for-network-testing-tools",{"title":510,"description":970},"3.blog\u002F2019\u002Fancientt-automation-for-network-testing-tools","rve0kHeI3YnjvoUDQO2ohnvLELd5CsUOkx_GCQF9Rio",[987,992],{"title":988,"path":989,"stem":990,"description":991,"children":-1},"What exactly is „Cloud Native\" even?","\u002Fblog\u002F2018\u002Fwhat-exactly-is-cloud-native-even","3.blog\u002F2018\u002Fwhat-exactly-is-cloud-native-even","Cross-Post of my \"What exactly is „Cloud Native\" even?\" article from \"The Cloud Report\"",{"title":993,"path":994,"stem":995,"description":996,"children":-1},"Container and Kubernetes Training","\u002Fblog\u002F2019\u002Fcontainer-and-kubernetes-training","3.blog\u002F2019\u002Fcontainer-and-kubernetes-training","Container und Kubernetes Training Material",1776891354292]