-mdi-file-edit-outline","\u002Fdocs\u002Fweb\u002Ftiptap","1.docs\u002Fweb\u002Ftiptap",[504],{"title":505,"path":506,"stem":507},"Snippets","\u002Fdocs\u002Fweb\u002Ftiptap\u002Fsnippets","1.docs\u002Fweb\u002Ftiptap\u002Fsnippets",{"id":509,"title":510,"authors":511,"badge":517,"body":518,"date":1161,"description":1162,"extension":1163,"image":1164,"meta":1165,"navigation":1003,"path":1171,"seo":1172,"stem":1173,"__hash__":1174},"posts\u002F3.blog\u002F2018\u002Fkubecon-copenhagen-2018-day-3.md","KubeCon Copenhagen 2018 - Day 3",[512],{"name":513,"to":514,"avatar":515},"Alexander Trost","https:\u002F\u002Fgithub.com\u002Fgalexrt",{"src":516},"\u002Fimages\u002Fprofile-picture.jpg",null,{"type":519,"value":520,"toc":1143},"minimark",[521,525,541,559,564,578,582,587,594,600,603,606,612,615,618,621,624,630,633,639,642,645,651,654,658,664,669,675,678,685,718,730,736,746,752,757,772,776,782,785,791,794,808,814,817,820,823,834,837,840,846,849,855,859,865,872,878,884,890,901,907,914,920,923,929,933,938,944,947,958,962,966,1000,1006,1009,1012,1020,1024,1030,1054,1056,1059,1065,1068,1074,1079,1082,1085,1091,1094,1100,1106,1112,1115,1121,1127,1133,1137,1140],[522,523,524],"style",{},"iframe{display: block; margin: auto;}",[526,527,528,536],"blockquote",{},[529,530,531,535],"p",{},[532,533,534],"strong",{},"NOTE"," All credit for the slides in the pictures goes to their creators!",[529,537,538,540],{},[532,539,534],{}," If you are in one of these pictures and want it removed, please contact me by email (see about\u002Fimprint page).",[526,542,543,552],{},[529,544,545,548,549],{},[532,546,547],{},"WIP"," This post is still work in progress! The content of this post can rapidly change.\nThis note will be removed when the post has been completed.\n",[532,550,551],{},"TODO",[553,554,555],"ol",{},[556,557,558],"li",{},"Proof read.",[560,561,563],"h2",{"id":562},"welcome","Welcome!",[529,565,566,567,572,573,577],{},"A warm \"Welcome\" if you are new to the three day post series from KubeCon Copenhagen, I recommend you to checkout the first day blog post too, here ",[568,569,571],"a",{"href":570},"\u002Fblog\u002F2018\u002FKubeCon-Copenhagen-2018-Day-1.md","KubeCon Copenhagen 2018 Day 1"," and the second day blog post, here ",[568,574,576],{"href":575},"\u002Fblog\u002F2018\u002FKubeCon-Copenhagen-2018-Day-2.md","KubeCon Copenhagen 2018 Day 2",".",[560,579,581],{"id":580},"morning-keynotes","Morning Keynotes",[583,584,586],"h3",{"id":585},"keynote-kubeflow-ml-on-kubernetes-david-aronchick-product-manager-cloud-ai-and-co-founder-of-kubeflow-google-vishnu-kannan-sr-software-engineer-google","Keynote: Kubeflow ML on Kubernetes - David Aronchick, Product Manager, Cloud AI and Co-Founder of Kubeflow, Google & Vishnu Kannan, Sr. Software Engineer, Google",[529,588,589],{},[590,591],"img",{"alt":592,"src":593},"KubeCon - Keynote - KubeCon Bingo","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_090657.jpg",[529,595,596],{},[590,597],{"alt":598,"src":599},"KubeCon - Keynote - Power effectiveness with AI","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_090844.jpg",[529,601,602],{},"Doing machine learning allowed Google to save up to 40% on their power bill.",[529,604,605],{},"Machine learning for cloud native, needs to be a) composable, b) Portability and c) Scalability.",[529,607,608],{},[590,609],{"alt":610,"src":611},"KubeCon - Keynote - Oh, you want to use ML on K8s?","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_091333.jpg",[529,613,614],{},"If you want to run ML on Kubernetes, you are gonna have a bad time, but not anymore thanks to KubeFlow.",[529,616,617],{},"It takes an expert for just ML, running it in Kubernetes is hard too, but KubeFlow can help.\nThey have released Kubeflow 0.1.\nIt is built so that you can customize it as you want.",[529,619,620],{},"Their demo showed an example of ML usage for finding the likeliness of reviews.",[529,622,623],{},"The \"normal\" way without ML just used predefined words to see how likely the review is to be either a recommendation, neutral or bad.",[529,625,626],{},[590,627],{"alt":628,"src":629},"KubeCon - Keynote - KubeFlow TensorBoard","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_092147.jpg",[529,631,632],{},"TensorBoard can be used to see some metrics about the metrics.",[529,634,635],{},[590,636],{"alt":637,"src":638},"KubeCon - Keynote - KubeFlow ML end result","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_092308.jpg",[529,640,641],{},"It is able to run on \"any\" K8S cloud.",[529,643,644],{},"A Swedish city had used data science to reduce injuries through new snowfall by optimizing the snowplow paths.",[529,646,647],{},[590,648],{"alt":649,"src":650},"KubeCon - Keynote - KubeFlow  - We're just getting started!","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_092657.jpg",[529,652,653],{},"Awesome, I will definitely try this out to get me started in ML.\nThe end goal is to make Kubernetes to number one platform for ML.",[583,655,657],{"id":656},"keynote-running-with-scissors-liz-rice-technology-evangelist-aqua-security","Keynote: Running with Scissors - Liz Rice, Technology Evangelist, Aqua Security",[529,659,660],{},[590,661],{"alt":662,"src":663},"KubeCon - Keynote - Running with Scissors Title","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_092956.jpg",[526,665,666],{},[529,667,668],{},"\"You might carry the scissors for miles before you cut yourself\"\n- Liz Rice",[529,670,671],{},[590,672],{"alt":673,"src":674},"KubeCon - Keynote - Container Isolation - View from Host","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_093323.jpg",[529,676,677],{},"Linux container isolation is mostly done through capabilities.\nA container run through Kubernetes (mostly likely also Docker) drops most \"bad\" capabilities\u002Fisn't even granted the capabilities on start.",[529,679,680,684],{},[681,682,683],"code",{},"securityContext",":",[686,687,688,694,712],"ul",{},[556,689,690,693],{},[681,691,692],{},"privileged: true"," gives all privileges.",[556,695,696,699,700,703,704,707,708,711],{},[681,697,698],{},"runAsNonRoot"," option sets the container to run the image as non root. Though the image needs to have ",[681,701,702],{},"USER 1000"," (where ",[681,705,706],{},"1000"," isn't ",[681,709,710],{},"0"," aka root) to be able to run otherwise Kubernetes will not be able to run.",[556,713,714,717],{},[681,715,716],{},"runAsUser"," force container process to be started as user ID (same exists for supplemental groups).",[529,719,720,721,723,724,577],{},"For more information see the ",[681,722,683],{}," documentation: ",[568,725,729],{"href":726,"rel":727},"https:\u002F\u002Fkubernetes.io\u002Fdocs\u002Ftasks\u002Fconfigure-pod-container\u002Fsecurity-context\u002F",[728],"nofollow","Kubernetes.io Documentation - Pod SecurityContext",[529,731,732],{},[590,733],{"alt":734,"src":735},"KubeCon - Keynote - Security with USER in Dockerfile","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_094113.jpg",[529,737,738,742,743,745],{},[590,739],{"alt":740,"src":741},"KubeCon - Keynote - Host can't remove root file created by root container as non root","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_094344.jpg","\nOne can potentially use a volume mount of the pod to access files from hosts and because the UID is ",[681,744,710],{}," aka root, everything can be done.",[529,747,748],{},[590,749],{"alt":750,"src":751},"KubeCon - Keynote - Stop running with scissors","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_094636.jpg",[526,753,754],{},[529,755,756],{},"\"We need to prevent us from running with scissors\"\n- Liz Rice",[553,758,759,766,769],{},[556,760,761,762,765],{},"Change applications Dockerfiles and add ",[681,763,764],{},"USER __YOUR_ID__"," line.",[556,767,768],{},"Use tools like from Aqua Security.",[556,770,771],{},"Use PodSecurityPolicies.",[583,773,775],{"id":774},"keynote-scaling-deep-learning-models-in-production-using-kubernetes-sahil-dua-software-developer-bookingcom","Keynote: Scaling Deep Learning Models in Production Using Kubernetes - Sahil Dua, Software Developer, Booking.com",[529,777,778],{},[590,779],{"alt":780,"src":781},"KubeCon - Keynote - Booking.com Scaling Highlights","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_095039.jpg",[529,783,784],{},"They run Deep Learning at huge scale.",[529,786,787],{},[590,788],{"alt":789,"src":790},"KubeCon - Keynote - Scaling Deep Learning Models in Production Using Kubernetes Title","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_095032.jpg",[529,792,793],{},"They use it for:",[686,795,796,799,802,805],{},[556,797,798],{},"Image Tagging",[556,800,801],{},"Translations",[556,803,804],{},"Advertisement bidding",[556,806,807],{},"And more..",[529,809,810],{},[590,811],{"alt":812,"src":813},"KubeCon - Keynote - Booking.com Image Tagging","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_095350.jpg",[529,815,816],{},"Once they have the tags on the images the user is able to better search for certain factors of a hotel\u002Froom.",[529,818,819],{},"The workload for deep learning is immmensive. From 10 to 100s of GBs to sometimes even terrabytes of data to go through.",[529,821,822],{},"They choose Kubernetes because of the:",[686,824,825,828,831],{},[556,826,827],{},"Isolation",[556,829,830],{},"Elasticity",[556,832,833],{},"Flexibility",[529,835,836],{},"They don't put training data into the images. This removes the need to always repull the image.\nThey simply use Hadoop or PVs to access\u002Fmount the training data.",[529,838,839],{},"I recommend to checkout the recording as he made a nice graphical visualization on their setup.",[529,841,842],{},[590,843],{"alt":844,"src":845},"KubeCon - Keynote - Booking.com Serving ML Predictions 1","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_100114.jpg",[529,847,848],{},"They use common code (possibly a library) which contains access instructions to the model(s). To that they containerize the application, but without the model in it.\nThe model is loaded in memory \"on demand\" from Hadoop storage and then it begins to serve the predictions.",[529,850,851],{},[590,852],{"alt":853,"src":854},"KubeCon - Keynote - Booking.com Serving ML Predictions 2","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_100355.jpg",[583,856,858],{"id":857},"keynote-crossing-the-river-by-feeling-the-stones-simon-wardley-researcher-leading-edge-forum","Keynote: Crossing the River by Feeling the Stones - Simon Wardley, Researcher, Leading Edge Forum",[529,860,861],{},[590,862],{"alt":863,"src":864},"KubeCon - Keynote - Crossing the River by Feeling the Stones - Title","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_100931.jpg",[529,866,867,871],{},[590,868],{"alt":869,"src":870},"KubeCon - Keynote - Crossing the River by Feeling the Stones - Common Blahs","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_101057.jpg","\n(blah, blah, blah)",[529,873,874],{},[590,875],{"alt":876,"src":877},"KubeCon - Keynote - Crossing the River by Feeling the Stones - Blah Template","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_101133.jpg",[529,879,880],{},[590,881],{"alt":882,"src":883},"KubeCon - Keynote - Crossing the River by Feeling the Stones - Auto generate strategies","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_101136.jpg",[529,885,886],{},[590,887],{"alt":888,"src":889},"KubeCon - Keynote - Crossing the River by Feeling the Stones - Three main feedback points for his autogenerated strategies","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_101242.jpg",[529,891,892,896],{},[590,893],{"alt":894,"src":895},"KubeCon - Keynote - Crossing the River by Feeling the Stones - Automatic Strategy Generator Online","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_101252.jpg",[568,897,900],{"href":898,"rel":899},"http:\u002F\u002Fstrategy-madlibs.herokuapp.com",[728],"Automatic Strategy Generator Online",[529,902,903],{},[590,904],{"alt":905,"src":906},"KubeCon - Keynote - Crossing the River by Feeling the Stones - Four fields","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_101657.jpg",[529,908,909,913],{},[590,910],{"alt":911,"src":912},"KubeCon - Keynote - Crossing the River by Feeling the Stones - 'The End of cloud is neigh ...'","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_102829_1.jpg","\n'The End of cloud is neigh ...'",[529,915,916],{},[590,917],{"alt":918,"src":919},"KubeCon - Keynote - Crossing the River by Feeling the Stones - Circle of purpose and movement","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_103047.jpg",[529,921,922],{},"This was the funniest keynote, you have to checkout the recording of it if you weren't there.",[529,924,925],{},[590,926],{"alt":927,"src":928},"KubeCon - Keynote - Crossing the River by Feeling the Stones - Deng Xiaoping Quote","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_103051.jpg",[583,930,932],{"id":931},"keynote-closing-remarks-kelsey-hightower-kubernetes-community-member-google-liz-rice-technology-evangelist-aqua-security","Keynote: Closing Remarks – Kelsey Hightower, Kubernetes Community Member, Google & Liz Rice, Technology Evangelist, Aqua Security",[526,934,935],{},[529,936,937],{},"\"You feel the AC?\"\n- Kelsey Hightower",[529,939,940],{},[590,941],{"alt":942,"src":943},"KubeCon - Keynote - Closing Remarks - Upcoming conferences","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_103242.jpg",[529,945,946],{},"The upcoming CloudNativeCon and KubeCon will be at:",[686,948,949,952,955],{},[556,950,951],{},"Shanghai, China: November 14-15. 2018",[556,953,954],{},"Seattle, North America: December 11-13. 2018",[556,956,957],{},"Barcelona, Europe: May 21-23. 2019",[560,959,961],{"id":960},"talks","Talks",[583,963,965],{"id":964},"rook-deep-dive-bassam-tabbara-tony-allen-jared-watts-upbound-intermediate-skill-level","Rook Deep Dive – Bassam Tabbara, Tony Allen & Jared Watts, Upbound (Intermediate Skill Level)",[526,967,972,995,996],{"className":968,"dataLang":971},[969,970],"twitter-tweet","tw-align-center","en",[529,973,975,976,980,981,985,986,990,991],{"lang":971,"dir":974},"ltr","full room for the ",[568,977,979],{"href":978},"https:\u002F\u002Ftwitter.com\u002Frook_io?ref_src=twsrc%5Etfw","@rook_io","  deep dive.  actually 2 deep dives, one for developers and one for administrators. great job ",[568,982,984],{"href":983},"https:\u002F\u002Ftwitter.com\u002Ftonya11en?ref_src=twsrc%5Etfw","@tonya11en","  and ",[568,987,989],{"href":988},"https:\u002F\u002Ftwitter.com\u002Fgalexrt?ref_src=twsrc%5Etfw","@galexrt","! ",[568,992,994],{"href":993},"https:\u002F\u002Ft.co\u002FLqszC4Qzdl","pic.twitter.com\u002FLqszC4Qzdl","— Jared Watts (@jbw976) ",[568,997,999],{"href":998},"https:\u002F\u002Ftwitter.com\u002Fjbw976\u002Fstatus\u002F992412121538465792?ref_src=twsrc%5Etfw","May 4, 2018",[1001,1002],"script",{"async":1003,"src":1004,"charSet":1005},true,"https:\u002F\u002Fplatform.twitter.com\u002Fwidgets.js","utf-8",[529,1007,1008],{},"First of all thanks for coming to the talk!\nA big thanks also goes out to Jared and Tony that I could talk about the administrative side of Rook. I really enjoyed helping with the slides.",[529,1010,1011],{},"I hope everyone liked the talk. If you have feedback about the talk, get in touch with Jared, Tony or me.",[529,1013,1014,1015,577],{},"Be sure to follow Jared's Twitter ",[568,1016,1019],{"href":1017,"rel":1018},"https:\u002F\u002Ftwitter.com\u002Fjbw976",[728],"@jbw976",[583,1021,1023],{"id":1022},"kubernetes-runs-anywhere-but-does-your-data-jared-watts-upbound-beginner-skill-level","Kubernetes Runs Anywhere, but Does your Data? - Jared Watts, Upbound (Beginner Skill Level)",[529,1025,1026],{},[590,1027],{"alt":1028,"src":1029},"KubeCon - Talk - Kubernetes Runs Anywhere, but Does your Data? Title","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_144545.jpg",[526,1031,1033,1050,1051],{"className":1032,"dataLang":971},[969,970],[529,1034,1035,1038,1039,1043,1044,1043,1046],{"lang":971,"dir":974},[568,1036,1019],{"href":1037},"https:\u002F\u002Ftwitter.com\u002Fjbw976?ref_src=twsrc%5Etfw"," fills the auditorium talking about portability of stateful workloads across clouds? ",[568,1040,1042],{"href":1041},"https:\u002F\u002Ftwitter.com\u002Fhashtag\u002Fkubecon?src=hash&ref_src=twsrc%5Etfw","#kubecon"," ",[568,1045,979],{"href":978},[568,1047,1049],{"href":1048},"https:\u002F\u002Ft.co\u002FbmqkmVaBbS","pic.twitter.com\u002FbmqkmVaBbS","— bassam (@bassamtabbara) ",[568,1052,999],{"href":1053},"https:\u002F\u002Ftwitter.com\u002Fbassamtabbara\u002Fstatus\u002F992385488500772864?ref_src=twsrc%5Etfw",[1001,1055],{"async":1003,"src":1004,"charSet":1005},[529,1057,1058],{},"Kubernetes runs anywhere (even on a robot vacuum cleaner).\nThe power of Kubernetes is also Portability.",[529,1060,1061],{},[590,1062],{"alt":1063,"src":1064},"KubeCon - Talk - Kubernetes Runs Anywhere, but Does your Data? - How does Kubernetes do it?","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_144900.jpg",[529,1066,1067],{},"There are abstractions for running applications in Kubernetse but also already for Storage in general.\nStorage abstraction is available through PersistentVolumes, PersistentVolumeClaims and more.",[529,1069,1070],{},[590,1071],{"alt":1072,"src":1073},"KubeCon - Talk - Kubernetes Runs Anywhere, but Does your Data? - Where Storage Falls Short","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_145357.jpg",[529,1075,1076],{},[590,1077],{"alt":1072,"src":1078},"\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_145458.jpg",[529,1080,1081],{},"The provisioning is still more in the background than consuming storage.\nThis will change with ContainerStorageInterface (CSI).",[529,1083,1084],{},"To be able to run stateful applications anywhere you need a portable storage solutions.\nCRDs can be used to create abstractions.",[529,1086,1087],{},[590,1088],{"alt":1089,"src":1090},"KubeCon - Talk - Kubernetes Runs Anywhere, but Does your Data? - Operator's Control Loop","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_150229.jpg",[529,1092,1093],{},"On the first day you deploy, on the second you support it (Day 2 operations).",[529,1095,1096],{},[590,1097],{"alt":1098,"src":1099},"KubeCon - Talk - Kubernetes Runs Anywhere, but Does your Data? - Kubernetes API and Clientsets","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_150457.jpg",[529,1101,1102],{},[590,1103],{"alt":1104,"src":1105},"KubeCon - Talk - Kubernetes Runs Anywhere, but Does your Data? - Event Triggers","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_150734.jpg",[529,1107,1108],{},[590,1109],{"alt":1110,"src":1111},"KubeCon - Talk - Kubernetes Runs Anywhere, but Does your Data? - Demo Deployments spawned by a controller through a CRD 1","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_151151.jpg",[529,1113,1114],{},"The new WIP CockroachDB and Minio operator were show cased next to the Ceph one.",[529,1116,1117],{},[590,1118],{"alt":1119,"src":1120},"KubeCon - Talk - Kubernetes Runs Anywhere, but Does your Data? - Demo Deployments spawned by a controller through a CRD 2","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_151152.jpg",[529,1122,1123],{},[590,1124],{"alt":1125,"src":1126},"KubeCon - Talk - Kubernetes Runs Anywhere, but Does your Data? - Demo Deployments spawned by a controller through a CRD 3","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_151153.jpg",[529,1128,1129],{},[590,1130],{"alt":1131,"src":1132},"KubeCon - Talk - Kubernetes Runs Anywhere, but Does your Data? - Questions?","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3\u002Fimg_20180504_151613.jpg",[560,1134,1136],{"id":1135},"summary","Summary",[529,1138,1139],{},"As always KubeCon was awesome. I met amazing people, had very interesting talks and found new contacts.",[529,1141,1142],{},"Have Fun!",{"title":1144,"searchDepth":1145,"depth":1145,"links":1146},"",2,[1147,1148,1156,1160],{"id":562,"depth":1145,"text":563},{"id":580,"depth":1145,"text":581,"children":1149},[1150,1152,1153,1154,1155],{"id":585,"depth":1151,"text":586},3,{"id":656,"depth":1151,"text":657},{"id":774,"depth":1151,"text":775},{"id":857,"depth":1151,"text":858},{"id":931,"depth":1151,"text":932},{"id":960,"depth":1145,"text":961,"children":1157},[1158,1159],{"id":964,"depth":1151,"text":965},{"id":1022,"depth":1151,"text":1023},{"id":1135,"depth":1145,"text":1136},"2018-05-04T08:16:15+02:00","Talks, keynotes, thoughts and pictures from the KubeCon Copenhagen 2018 Day 3.","md",{"src":663},{"tags":1166},[1167,1168,1169,1170,124],"Conferences","KubeCon","Container","Docker","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-3",{"title":510,"description":1162},"3.blog\u002F2018\u002Fkubecon-copenhagen-2018-day-3","BuOkuspqxS3PvNUQMxhr0k-sCBnVoBKMV5A4o7ro7fQ",[1176,1181],{"title":1177,"path":1178,"stem":1179,"description":1180,"children":-1},"KubeCon Copenhagen 2018 - Day 2","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-2","3.blog\u002F2018\u002Fkubecon-copenhagen-2018-day-2","Talks, keynotes, thoughts and pictures from the KubeCon Copenhagen 2018 Day 2.",{"title":1182,"path":1183,"stem":1184,"description":1185,"children":-1},"My New Home Office Setup","\u002Fblog\u002F2018\u002Fmy-new-home-office-setup","3.blog\u002F2018\u002Fmy-new-home-office-setup","In this post I'm showing you my new gaming and home office setup.",1778525210630]