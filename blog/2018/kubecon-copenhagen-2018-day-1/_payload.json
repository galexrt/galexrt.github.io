-mdi-file-edit-outline","\u002Fdocs\u002Fweb\u002Ftiptap","1.docs\u002Fweb\u002Ftiptap",[504],{"title":505,"path":506,"stem":507},"Snippets","\u002Fdocs\u002Fweb\u002Ftiptap\u002Fsnippets","1.docs\u002Fweb\u002Ftiptap\u002Fsnippets",{"id":509,"title":510,"authors":511,"badge":517,"body":518,"date":1315,"description":1316,"extension":1317,"image":1318,"meta":1319,"navigation":1325,"path":1326,"seo":1327,"stem":1328,"__hash__":1329},"posts\u002F3.blog\u002F2018\u002Fkubecon-copenhagen-2018-day-1.md","KubeCon Copenhagen 2018 - Day 1",[512],{"name":513,"to":514,"avatar":515},"Alexander Trost","https:\u002F\u002Fgithub.com\u002Fgalexrt",{"src":516},"\u002Fimages\u002Fprofile-picture.jpg",null,{"type":519,"value":520,"toc":1287},"minimark",[521,525,551,556,559,563,568,575,581,584,590,597,602,605,616,622,631,635,638,643,650,675,682,689,693,736,743,746,753,760,763,767,770,774,781,785,788,793,797,800,807,814,821,824,828,834,840,843,849,852,855,861,864,870,876,885,889,892,898,903,906,910,916,919,924,930,935,938,941,947,950,956,961,964,970,973,979,984,992,996,1000,1003,1015,1018,1021,1024,1027,1037,1040,1043,1046,1052,1056,1059,1062,1068,1071,1074,1080,1086,1089,1092,1095,1101,1104,1109,1112,1120,1126,1130,1134,1141,1145,1151,1155,1161,1165,1171,1175,1178,1184,1187,1190,1195,1198,1203,1206,1209,1212,1217,1220,1224,1229,1234,1239,1247,1254,1258,1263,1268,1272,1275,1281,1284],[522,523,524],"style",{},"iframe{display: block; margin: auto;}",[526,527,528,535,538,542,545],"blockquote",{},[529,530,531],"p",{},[532,533,534],"strong",{},"NOTE",[529,536,537],{},"All credit for the slides in the pictures goes to their creators!",[529,539,540],{},[532,541,534],{},[529,543,544],{},"If you are in one of these pictures and want it removed, please contact me by email (see about\u002Fimprint page).",[529,546,547,550],{},[532,548,549],{},"WIP"," This post is still work in progress! The content of this post can rapidly change.\nThis note will be removed when the post has been completed.",[552,553,555],"h2",{"id":554},"welcome","Welcome!",[529,557,558],{},"A big welcome to everyone at KubeCon!\nI'm happy to have already met a good amount of Rooklers just during badge pickup.",[552,560,562],{"id":561},"morning-keynotes","Morning Keynotes",[564,565,567],"h3",{"id":566},"keynote-how-good-is-our-code-dan-kohn-executive-director-cloud-native-computing-foundation","Keynote: How Good Is Our Code? - Dan Kohn, Executive Director, Cloud Native Computing Foundation",[529,569,570],{},[571,572],"img",{"alt":573,"src":574},"KubeCon - Keynote - How Good Is Our Code? - KubeCon Attendees","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_090721.jpg",[529,576,577],{},[571,578],{"alt":579,"src":580},"KubeCon - Keynote - How Good Is Our Code? - CNCF is a critical part","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_090724.jpg",[529,582,583],{},"SQLite is a good example for test coverage, because they have 100% coverage. But even though they have a test coverage of 100%, bugs have been found with a \"magic\" genetic bug finder program.\nBugs in such a case are hopefully just caused by usages that the developers hasn't thought about and because of that has not tested for.",[529,585,586],{},[571,587],{"alt":588,"src":589},"KubeCon: Tweet about code quality","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_091220.jpg",[529,591,592,596],{},[571,593],{"alt":594,"src":595},"KubeCon: SLOCs for the cloud trail map application and stack","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_091534.jpg","\n(SLOCs are lines of code)",[526,598,599],{},[529,600,601],{},"\"A patch doesn't help until it is deployed to production\" (Continous Integration)\n- Dan Kohn",[529,603,604],{},"CI should run multiple types of tests, smoke, integration, unit.\nAs Kelsey Hightwoer wrote in a tweet, if you don't have CI for your application, Kubernetes is your smallest problem.",[529,606,607,608,615],{},"A cloud native trail map is available at the CNCF sponsor showcase booth or online at ",[609,610,614],"a",{"href":611,"rel":612},"https:\u002F\u002Fl.cncf.io",[613],"nofollow","l.cncf.io",".\nYour adventure though should first lead to containers of your applications, because containerized CI is easier to do.",[529,617,618],{},[571,619],{"alt":620,"src":621},"KubeCon - Keynote - Kelsey Hightower is showin of nocode repository","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_092644.jpg",[529,623,624,625,630],{},"Kelsey Hightwoer showed his ",[609,626,629],{"href":627,"rel":628},"https:\u002F\u002Fgithub.com\u002Fkelseyhightwoer\u002Fnocode",[613],"GitHub kelseyhightwoer\u002Fnocode"," \"tutorial\". It was hilarious, definitely checkout the keynote recording for that.",[564,632,634],{"id":633},"keynote-cncf-project-update-liz-rice-technology-evangelist-aqua-security-sugu-sougoumarane-cto-planetscale-data-colin-sullivan-product-manager-synadia-communications-inc-andrew-jessup-co-founder-scytale-inc","Keynote: CNCF Project Update - Liz Rice, Technology Evangelist, Aqua Security; Sugu Sougoumarane, CTO, PlanetScale Data; Colin Sullivan, Product Manager, Synadia Communications, Inc. & Andrew Jessup, Co-founder Scytale Inc.",[529,636,637],{},"Currently there is a total of 20 projects in the CNCF.",[639,640,642],"h4",{"id":641},"sandbox-projects","Sandbox projects",[529,644,645,649],{},[571,646],{"alt":647,"src":648},"KubeCon - Keynote - Rook was showed as one of the sandbox projects","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_092918.jpg","\n(FTW! I'm totatlly not biased;))",[651,652,653,660,667],"ul",{},[654,655,656],"li",{},[609,657,465],{"href":658,"rel":659},"https:\u002F\u002Frook.io\u002F",[613],[654,661,662],{},[609,663,666],{"href":664,"rel":665},"https:\u002F\u002Fwww.openpolicyagent.org\u002F",[613],"Open Policy Agent",[654,668,669,674],{},[609,670,673],{"href":671,"rel":672},"https:\u002F\u002Fspiffe.io\u002F",[613],"SPIFFE & SPIRE"," - Tries to solve the problem of trust between workloads. Looks interesting to clear up the authentication\u002Ftrust issues currently broadly existing.",[529,676,677,681],{},[571,678],{"alt":679,"src":680},"KubeCon - Keynote - In a multi cloud world, who is establishing the trust?","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_093118.jpg","\nIn a multi cloud world, who is establishing the trust?",[529,683,684,688],{},[571,685],{"alt":686,"src":687},"KubeCon - Keynote - SPIFFE & SPIRE can be a solution to improve the situation","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_093446.jpg","\nSPIFFE & SPIRE can be a solution to improve the situation",[639,690,692],{"id":691},"incubation-projects","Incubation projects",[651,694,695,698,701,704,706,709,712,715,718,721,724,727,730,733],{},[654,696,697],{},"coreDNS",[654,699,700],{},"Linkerd",[654,702,703],{},"Envoy",[654,705,292],{},[654,707,708],{},"OpenTracing (Updated APIs and libraries for a total of 9 languages)",[654,710,711],{},"Jaeger",[654,713,714],{},"Fluentd",[654,716,717],{},"NATS - Already has some CNCF Projects integration, like Prometheus",[654,719,720],{},"Container Network Interface (CNI)",[654,722,723],{},"GRPC",[654,725,726],{},"containerd (v1.1 Support for Kubernetes CRI)",[654,728,729],{},"TUF (Secure framework for software updates)",[654,731,732],{},"Notary (based on TUF, for secure software distribution)",[654,734,735],{},"Vitess (database orchestration for MySQL horizontal scaling, takes away the pain of sharding in the application)",[529,737,738,742],{},[571,739],{"alt":740,"src":741},"KubeCon - Keynote - NATS feature list","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_094316.jpg","\nNATS feature list",[529,744,745],{},"Vitess showed an interesting demo:",[529,747,748,752],{},[571,749],{"alt":750,"src":751},"KubeCon - Keynote - Grafana dashboard showing the Vitess Gateway QPS and other metrics","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_095500.jpg","\nGrafana dashboard showing the Vitess Gateway QPS and other metrics",[529,754,755,759],{},[571,756],{"alt":757,"src":758},"KubeCon - Keynote - Vitess webinterface before telling Vitess to use the shards","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_095507.jpg","\nVitess webinterface before telling Vitess to use the shards",[529,761,762],{},"It is easy and awesome looking! They have a simple to use cli tool to execute tasks, but it seems that everything is managed through Kubernetes.",[639,764,766],{"id":765},"graduated-projects","Graduated Projects",[529,768,769],{},"Kubernetes is the first project that has graduated.",[639,771,773],{"id":772},"what-is-graduation","What is graduation?",[529,775,776,780],{},[571,777],{"alt":778,"src":779},"KubeCon - Keynote - Graduation 'graph'","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_095905.jpg","\nGraduation 'graph'",[639,782,784],{"id":783},"getting-involved-into-cncf-projects","Getting involved into CNCF projects",[529,786,787],{},"Track sessions about \"nuts and bolts\" of projects\u002Fimplementations-\nIntros & Deep Dives of the Projects, Kubernetes SIG and CNCF working groups.\nHallway Track to meet people in the hallway to find out about others problems and solutions.",[529,789,790],{},[532,791,792],{},"You are the community!",[564,794,796],{"id":795},"keynote-re-thinking-networking-for-microservices-lew-tucker-vpcto-cloud-computing-cisco-systems-inc","Keynote: Re-thinking Networking for Microservices - Lew Tucker, VP\u002FCTO Cloud Computing, Cisco Systems, Inc.",[529,798,799],{},"Cisco has created \"Cisco Container Platform\".",[529,801,802,806],{},[571,803],{"alt":804,"src":805},"KubeCon - Keynote - Shift in how apps are built","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_100711.jpg","\nThere is a shift in how apps are built.",[529,808,809,813],{},[571,810],{"alt":811,"src":812},"KubeCon - Keynote - 'Services should be simple but get complicated fast'","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_100823.jpg","\n'Services should be simple but get complicated fast'",[529,815,816,820],{},[571,817],{"alt":818,"src":819},"KubeCon - Keynote - Handing-off certain tasks to a service mesh","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_100857.jpg","\nHanding-off certain tasks to a service mesh.",[529,822,823],{},"Using a service mesh allows to not modify the service's code to get it more \"secure\".",[564,825,827],{"id":826},"keynote-cern-experiences-with-multi-cloud-federated-kubernetes-ricardo-rocha-staff-member-cern-clenimar-filemon-software-engineer-federal-university-of-campina-grande","Keynote: CERN Experiences with Multi-Cloud Federated Kubernetes - Ricardo Rocha, Staff Member, CERN & Clenimar Filemon, Software Engineer, Federal University of Campina Grande",[529,829,830],{},[571,831],{"alt":832,"src":833},"KubeCon - Keynote - CERN map of LHCb","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_101328.jpg",[529,835,836],{},[571,837],{"alt":838,"src":839},"KubeCon - Keynote - How much data is collected at CERN LHCb","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_101706.jpg",[529,841,842],{},"They have a lot of data up to 1PB\u002Fsec, but it is filtered and in the end it can be about 1-10GB\u002Fs.\nOver 200 Kubernetes are already running, from small to large clusters.",[529,844,845],{},[571,846],{"alt":847,"src":848},"KubeCon - Keynote - Numbers about Compute power at CERN","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_101910.jpg",[529,850,851],{},"Their numbers are extremely high in comparison to some big companies.",[529,853,854],{},"Their motivation for Federation is the uniform API for deployments, load balancing and much more.\nIt is especially good for their use cases with batch jobs, done with HTCondur. HTCondur allows for good scheduling by taking fair share and preemption into account. But HTCondur needs external storage and networking.\nThey have containerized the whole thing and use the Kubernetes Federation on \"all\" of their clusters dedicated to HTCondur.",[529,856,857],{},[571,858],{"alt":859,"src":860},"KubeCon - Keynote - Distributed computing","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_102000.jpg",[529,862,863],{},"Through the federation new nodes can be added to any cluster at any time, and through a DaemonSet automatically pick up the work especially for a tool such as HTCondur which uses a node agent for it's own node registration.",[529,865,866],{},[571,867],{"alt":868,"src":869},"KubeCon - Keynote - Setup with Startd and Kubernetes Federation use","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_102611.jpg",[529,871,872],{},[571,873],{"alt":874,"src":875},"KubeCon - Keynote - Workflow visualization for their distributed computing tasks","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_103048.jpg",[529,877,878,879,884],{},"Their demo showed how to run complex jobs on multiple Kubernetes clusters with federation.\nFor the visualization program, it can probably found here: ",[609,880,883],{"href":881,"rel":882},"https:\u002F\u002Fgithub.com\u002Frecast-hep",[613],"GitHub recast-hep",".",[564,886,888],{"id":887},"keynote-from-innovation-to-production-dirk-hohndel-vp-chief-open-source-officer-vmware","Keynote: From Innovation to Production - Dirk Hohndel, VP & Chief Open Source Officer, VMware",[529,890,891],{},"They created a product using open source.",[529,893,894],{},[571,895],{"alt":896,"src":897},"KubeCon - Keynote - VMWare Open Source Office Hours during KubeCon","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_103600.jpg",[526,899,900],{},[529,901,902],{},"\"Innovation is done by individuals\"\n- Dirk Hohndel",[529,904,905],{},"It is time to invest in minorities in the IT field. Opportunities need to be created for them.",[564,907,909],{"id":908},"keynote-cncf-20-20-vision-alexis-richardson-founder-ceo-weaveworks","Keynote: CNCF 20-20 Vision - Alexis Richardson, Founder & CEO, Weaveworks",[529,911,912],{},[571,913],{"alt":914,"src":915},"KubeCon - Keynote - Alexis Richardson on stage","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_104011.jpg",[529,917,918],{},"CNCF until now was kind of in a \"start up\" phase as a company. Which now more and more moves to getting \"Acceptance\".",[526,920,921],{},[529,922,923],{},"\"We are not a start up any more\"\n- Alexis Richardson",[529,925,926],{},[571,927],{"alt":928,"src":929},"KubeCon - Keynote - Why a platform?","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_104339_1.jpg",[526,931,932],{},[529,933,934],{},"\"For a lot of people 'cloud native' is just 'cloud'\"\n- Alexis Richardson",[529,936,937],{},"Today it is pretty easy to install a project such as Hadoop for data analysis or TensorFlow for machine learning with KubeFlow in Kubernetes.",[529,939,940],{},"Deploying faster allows for a higher velocity of applications\u002Fproducts (lower Time To Market).",[529,942,943],{},[571,944],{"alt":945,"src":946},"KubeCon - Keynote - '2018: We have KubeFloW'","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_104717.jpg",[529,948,949],{},"Everybody can do this faster and faster with CNCF projects.",[529,951,952],{},[571,953],{"alt":954,"src":955},"KubeCon - Keynote - High Velocity","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_104454.jpg",[526,957,958],{},[529,959,960],{},"\"Just run my code\"\n- Alexis Richardson",[529,962,963],{},"It shouldn't be run my applicatiom\u002Fcontainer anymore, it should just be as simple as git pushing the code and automatically pushed out to your platform, e.g. Kubernetes.",[529,965,966],{},[571,967],{"alt":968,"src":969},"KubeCon - Keynote - The key pieces we need","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_104830.jpg",[529,971,972],{},"Code centric by using git as the central point for the code and as the trigger for CI + CD.",[529,974,975],{},[571,976],{"alt":977,"src":978},"KubeCon - Keynote - New ways of working","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_105338.jpg",[526,980,981],{},[529,982,983],{},"\"What is missing? The developers.\"",[529,985,986,987,991],{},"Ethics are more and more important with the greater tools which given even greater power.\n",[571,988],{"alt":989,"src":990},"KubeCon - Keynote - Ethics are more important than ever","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_105559.jpg","\nEthics are more important than ever (looking at you Zuckerberg).",[552,993,995],{"id":994},"talks","Talks",[564,997,999],{"id":998},"replacing-nginx-with-envoy-in-a-traffic-control-system-mark-mcbride-turbine-labs-inc-advanced-skill-level","Replacing NGINX with Envoy in a Traffic Control System - Mark McBride, Turbine Labs, Inc (Advanced Skill Level)",[529,1001,1002],{},"A point for Envoy is that it is more made for a cloud native environment that changes fast.",[529,1004,1005,1006,1010,1011,1014],{},"NGINX does not have a great amount of routing options besides ",[1007,1008,1009],"code",{},"location"," and ",[1007,1012,1013],{},"redirect",". The routing in Envoy can be more dynamic, it is more made to route on facts besides the URI and\u002For server name which NGINX is mostly used for. It can possibly route on \"fact\" is this QA or Live? Which application version?\nEnvoy has taken notice of the already pretty good reload functionality and does it more dynamically.",[529,1016,1017],{},"Together with the overall dynamic in the routing, it is much more sophisticated than NGINX.\nStill to keep in mind, most software has good reason to co-exist beside each other depending on the task it should suffice in.",[529,1019,1020],{},"A good amount of big companies are maintainers on the project. To that over 50% of commits were made by people outside those companies.",[529,1022,1023],{},"Envoy is not reaching the current benchmarks looking at NGINX (and other webservers), but Envoy gives you more dynamic for a little bit less performance.\nA company has to look into the features, like filtering, of Envoy and the trade off, less performance, in comparison to the other existing solutions.",[529,1025,1026],{},"Migrations need to have enough people knowing what is going on and how to roll it back in case of failure.\nTo that a list of points that need to watched out for during the rollout (e.g. latencies) should be made and a list of tasks to be done for the actual \"piece by piece\" rollout.",[526,1028,1029],{},[529,1030,1031,1032,1036],{},"\"Know when to roll back",[1033,1034,1035],"span",{},"...","\"\n- Mark McBride",[529,1038,1039],{},"Health checks from their perspective are only good for \"Yes, I'm listening on that port\u002Faccepting requests\" and not is the application \"working\" (e.g. successfully processing requests\u002Fdata).",[529,1041,1042],{},"They are looking into open sourcing applications that can speed up own migrations.",[529,1044,1045],{},"I'd recommend to checkout the recording of the talk as there is a good amount of Envoy stuff and overall how one would roll this out explained.",[529,1047,1048],{},[571,1049],{"alt":1050,"src":1051},"KubeCon: Replacing NGINX with Envoy in a Traffic Control System - Thank You","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_143426.jpg",[564,1053,1055],{"id":1054},"rook-project-intro-bassam-tabbara-tony-allen-jared-watts-upbound-any-skill-level","Rook Project Intro – Bassam Tabbara, Tony Allen & Jared Watts, Upbound (Any Skill Level)",[529,1057,1058],{},"Rook takes the load of managing storage backends in Kubernetes of your shoulders.",[529,1060,1061],{},"It solves the limitations of each cloud providers having it's own storage aka vendor locking with the cloud.\nRook runs the storage ON the Kubernetes cluster which allows stateful workload to be moved more consistently between different clouds because the storage configuration stays the same.\nWith the storage configuration staying the same on each cloud, Rook has created a working abstraction between different clouds.",[529,1063,1064],{},[571,1065],{"alt":1066,"src":1067},"KubeCon: Rook Project Intro","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_162516.jpg",[529,1069,1070],{},"With the upcoming support for CockroachDB and Minio, this will even further move to decouple certain applications from each cloud providers.",[529,1072,1073],{},"Rook uses the same patterns as for example CoreOS's etcd-operator or their prometheus-operator.\nRook goes beyond that with managing\u002Foperating each storage \"backend\" to a certain aspect to as written take the load of the shoulders of the user.",[529,1075,1076],{},[571,1077],{"alt":1078,"src":1079},"KubeCon: Storage ON Kubernetes","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_162919.jpg",[529,1081,1082],{},[571,1083],{"alt":1084,"src":1085},"KubeCon: Rook Architecture","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_163713.jpg",[529,1087,1088],{},"In point of managing\u002Foperating, the Rook operator makes sure the cluster is healthy and also provisions the storage for the storage.",[529,1090,1091],{},"Rook tries to be more of a framework for storage solutions, next to Ceph there will be as mentioned soon be support for CockroachDB, Minio, Nexenta Storage and more.\nIt allows current storage providers to simply integrate with Rook and let it do the \"dirty\" work. This is good as some storage providers can with that \"move\" the workload to the community to implement and possibly add best practices to health checks.",[529,1093,1094],{},"In the demo he went through the quickstart guide and showed an example with WordPress which used block storage.",[529,1096,1097],{},[571,1098],{"alt":1099,"src":1100},"KubeCon: Rook Demo WordPress and MySQL example","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_164538.jpg",[529,1102,1103],{},"The cluster is now ready to be used after maybe 20-45 seconds.",[529,1105,1106],{},[571,1107],{"alt":1099,"src":1108},"\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_165002.jpg",[529,1110,1111],{},"Killing the MySQL pod didn't cause issues, because Kubernetes brought a new one and Rook agent made sure that it is only used after the other one is terminated (fencing).",[529,1113,1114,1115,884],{},"That is it for the intro, if you want to know more checkout ",[609,1116,1119],{"href":1117,"rel":1118},"https:\u002F\u002Frook.io",[613],"Rook.io",[529,1121,1122],{},[571,1123],{"alt":1124,"src":1125},"KubeCon: Rook Project Intro - 'Questions?'","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_165943.jpg",[552,1127,1129],{"id":1128},"evening-keynotes","Evening Keynotes",[564,1131,1133],{"id":1132},"keynote-anatomy-of-a-production-kubernetes-outage-oliver-beattie-head-of-engineering-monzo-bank","Keynote: Anatomy of a Production Kubernetes Outage - Oliver Beattie, Head of Engineering, Monzo Bank",[526,1135,1136],{},[529,1137,1138,1140],{},[532,1139,534],{}," I have not been to this keynotes. Just listing it here for completeness.",[564,1142,1144],{"id":1143},"keynote-container-native-dev-and-ops-experience-its-getting-easier-fast-ralph-squillace-principal-pm-azure-container-platform-microsoft","Keynote: Container-Native Dev-and-ops Experience: It's Getting Easier, Fast. - Ralph Squillace, Principal PM – Azure Container Platform, Microsoft",[526,1146,1147],{},[529,1148,1149,1140],{},[532,1150,534],{},[564,1152,1154],{"id":1153},"keynote-cloud-native-observability-security-from-google-cloud-craig-box-staff-developer-advocate-google","Keynote: Cloud Native Observability & Security from Google Cloud - Craig Box, Staff Developer Advocate, Google",[526,1156,1157],{},[529,1158,1159,1140],{},[532,1160,534],{},[564,1162,1164],{"id":1163},"keynote-cncf-end-user-awards-presented-by-chris-aniszczyk-coo-cloud-native-computing-foundation","Keynote: CNCF End User Awards - Presented by Chris Aniszczyk, COO, Cloud Native Computing Foundation",[526,1166,1167],{},[529,1168,1169,1140],{},[532,1170,534],{},[564,1172,1174],{"id":1173},"keynote-prometheus-20-the-next-scale-of-cloud-native-monitoring-fabian-reinartz-software-engineer-google","Keynote: Prometheus 2.0 – The Next Scale of Cloud Native Monitoring - Fabian Reinartz, Software Engineer, Google",[529,1176,1177],{},"They have more than 15000 stars on GitHub.\nThe first version was cut in March 2014, later on in January 2015 Prometheus was publicly announced.",[529,1179,1180],{},[571,1181],{"alt":1182,"src":1183},"KubeCon - Keynote - ","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_180204.jpg",[529,1185,1186],{},"For the Prometheus 2.0, they created a new TSDB engine for it as others wouldn't perform fast enough.\n\"Can persist 1.000.000+ samples\u002Fcore\u002Fsec to disk\"",[529,1188,1189],{},"After they optimized the TSDB, they noticed that all load was going outside the DB, especially the scrapping part of Prometheus.",[529,1191,1192],{},[571,1193],{"alt":1182,"src":1194},"\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_180548.jpg",[529,1196,1197],{},"With Prometheus 1.0 you would need to wait for weeks to see if the resources you gave it is enough.",[529,1199,1200],{},[571,1201],{"alt":1182,"src":1202},"\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_180740.jpg",[529,1204,1205],{},"With Prometheus 2 they also massively increased the query latency which was getting more and more with Prometheus 1.",[529,1207,1208],{},"Staleness has also been improved in Prometheus 2. These improvements made the alerting more agile due to the faster triggering of \"missing\" data.",[529,1210,1211],{},"They want to stay engaged with OpenMetrics.",[529,1213,1214],{},[571,1215],{"alt":1182,"src":1216},"\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_181256.jpg",[529,1218,1219],{},"There is a book available \"Prometheus Up & Running\" and free for the next 30 days for KubeCon goers.",[564,1221,1223],{"id":1222},"keynote-serverless-not-so-faas-kelsey-hightower-kubernetes-community-member-google","Keynote: Serverless, Not So FaaS - Kelsey Hightower, Kubernetes Community Member, Google",[526,1225,1226],{},[529,1227,1228],{},"\"That's where I come in and steal your servers\"\n- Kelsey Hightwoer",[529,1230,1231],{},[571,1232],{"alt":1182,"src":1233},"\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_181734.jpg",[526,1235,1236],{},[529,1237,1238],{},"\"Don't standardize all events. The envelope is enough\"\n- Kelsey Hightower",[529,1240,1241,1242,884],{},"A standardized event envelope can be found ",[609,1243,1246],{"href":1244,"rel":1245},"https:\u002F\u002Fcloudevents.io",[613],"here",[529,1248,1249],{},[609,1250,1253],{"href":1251,"rel":1252},"https:\u002F\u002Fserverless.com",[613],"Serverless Event Gateway",[564,1255,1257],{"id":1256},"keynote-closing-remarks-liz-rice-technology-evangelist-aqua-security","Keynote: Closing Remarks - Liz Rice, Technology Evangelist, Aqua Security",[529,1259,1260],{},[571,1261],{"alt":1182,"src":1262},"\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_183114.jpg",[526,1264,1265],{},[529,1266,1267],{},"\"Just follow the smell of sponsors\"\n- Liz Rice",[552,1269,1271],{"id":1270},"summary","Summary",[529,1273,1274],{},"Thanks for the beer CNCF and KubeCon!",[529,1276,1277],{},[571,1278],{"alt":1279,"src":1280},"KubeCon: Summary - Beer","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1\u002Fimg_20180502_185215.jpg",[529,1282,1283],{},"It was nice meeting a lot of new people and people from Rook Slack in person.",[529,1285,1286],{},"Have Fun!",{"title":1288,"searchDepth":1289,"depth":1289,"links":1290},"",2,[1291,1292,1301,1305,1314],{"id":554,"depth":1289,"text":555},{"id":561,"depth":1289,"text":562,"children":1293},[1294,1296,1297,1298,1299,1300],{"id":566,"depth":1295,"text":567},3,{"id":633,"depth":1295,"text":634},{"id":795,"depth":1295,"text":796},{"id":826,"depth":1295,"text":827},{"id":887,"depth":1295,"text":888},{"id":908,"depth":1295,"text":909},{"id":994,"depth":1289,"text":995,"children":1302},[1303,1304],{"id":998,"depth":1295,"text":999},{"id":1054,"depth":1295,"text":1055},{"id":1128,"depth":1289,"text":1129,"children":1306},[1307,1308,1309,1310,1311,1312,1313],{"id":1132,"depth":1295,"text":1133},{"id":1143,"depth":1295,"text":1144},{"id":1153,"depth":1295,"text":1154},{"id":1163,"depth":1295,"text":1164},{"id":1173,"depth":1295,"text":1174},{"id":1222,"depth":1295,"text":1223},{"id":1256,"depth":1295,"text":1257},{"id":1270,"depth":1289,"text":1271},"2018-05-01T07:45:25+02:00","Talks, keynotes, thoughts and pictures from the KubeCon Copenhagen 2018 Day 1.","md",{"src":589},{"tags":1320},[1321,1322,1323,1324,124],"Conferences","KubeCon","Container","Docker",true,"\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-1",{"title":510,"description":1316},"3.blog\u002F2018\u002Fkubecon-copenhagen-2018-day-1","r8MJ1U4aUgZ61EEF1nfoR2a0h2ePsylgQFeXdla0hMg",[1331,1336],{"title":1332,"path":1333,"stem":1334,"description":1335,"children":-1},"KubeCon Austin 2017 (Recap) Presentation","\u002Fblog\u002F2018\u002Fkubecon-austin-2017-recap-presentation","3.blog\u002F2018\u002Fkubecon-austin-2017-recap-presentation","A recap presentation about the KubeCon Austin 2017.",{"title":1337,"path":1338,"stem":1339,"description":1340,"children":-1},"KubeCon Copenhagen 2018 - Day 2","\u002Fblog\u002F2018\u002Fkubecon-copenhagen-2018-day-2","3.blog\u002F2018\u002Fkubecon-copenhagen-2018-day-2","Talks, keynotes, thoughts and pictures from the KubeCon Copenhagen 2018 Day 2.",1778881468287]